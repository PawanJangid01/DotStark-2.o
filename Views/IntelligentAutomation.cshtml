@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.IntelligentAutomation>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}
@section Styles {
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primarycss: 228, 100%, 55%;
      --bg: #ffffff;
      --surface: #f5f5f5;
      --border: #e5e5e5;
      --text-bright: #000000;
      --text-base: #1a1a1a;
      --text-dim: #6b7280;
      --text-muted: #9ca3af;
      --primary-color: hsl(228, 100%, 55%);
      --primary-light: hsl(228, 100%, 72%);
      --primary-bg: hsl(228, 100%, 96%);
      --radius: 0.5rem;
    }

    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text-base);
      -webkit-font-smoothing: antialiased;
      line-height: 1.6;
      overflow-x: hidden;
    }

    .section-padding { padding-left: 1.5rem; padding-right: 1.5rem; }
    @@media (min-width: 768px) { .section-padding { padding-left: 2rem; padding-right: 2rem; } }
    @@media (min-width: 1024px) { .section-padding { padding-left: 4rem; padding-right: 4rem; } }

    .gradient-text {
      background: hsl(var(--primarycss));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .surface-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
    }

    .glow-border {
      box-shadow: 0 0 0 1px var(--border), 0 0 20px -8px hsla(var(--primarycss), 0.3);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 600;
            padding: 0.6rem 1.4rem;
            font-size: 14px;
      border-radius: var(--radius);
      border: none;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--primary-color);
      color: #fff;
      box-shadow: 0 0 24px -4px hsla(var(--primarycss), 0.4);
    }
    .btn-primary:hover {
      background: hsl(228, 100%, 48%);
      box-shadow: 0 0 32px -4px hsla(var(--primarycss), 0.6);
    }

    .btn-outline {
      background: transparent;
      color: var(--text-base);
      border: 1px solid hsla(var(--primarycss), 0.4);
    }
    .btn-outline:hover {
    background: var(--foreground);
    color: var(--background);
    }

    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.7s cubic-bezier(0.16,1,0.3,1), transform 0.7s cubic-bezier(0.16,1,0.3,1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ---- HERO ---- */
    .hero {
      min-height: 85vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    
    .hero-content { position: relative; max-width: 56rem; margin: 0 auto; text-align: center; width: 100%; }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 1rem;
      border-radius: 9999px;
      border: 1px solid var(--border);
      background: var(--primary-bg);
      font-size: 0.875rem;
      color: var(--text-dim);
      margin-bottom: 2rem;
    }
    .hero h1 {
      font-size: clamp(2.25rem, 5vw, 4.5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.025em;
      margin-bottom: 1.5rem;
      color: var(--text-bright);
      text-wrap: balance;
    }
    .hero .sub { font-size: 1.125rem; color: var(--text-dim); max-width: 40rem; margin: 0 auto 1rem; }
    .hero .sub2 { font-size: 1rem; color: var(--text-muted); max-width: 36rem; margin: 0 auto 2.5rem; }

    /* ---- SECTION HEADERS ---- */
    .section-label {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--primary-color);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }
    .section-title {
      font-size: clamp(1.875rem, 3vw, 3rem);
      font-weight: 700;
      color: var(--text-bright);
      text-wrap: balance;
      margin-bottom: 1.5rem;
    }
    .section-desc { font-size: 1.125rem; color: var(--text-dim); max-width: 48rem; margin: 0 auto; }

    /* ---- SOLUTIONS GRID ---- */
    .solutions-grid { display: grid; gap: 1.5rem; }
    @@media (min-width: 768px) { .solutions-grid { grid-template-columns: repeat(2, 1fr); } }

    .solution-card { padding: 2rem; transition: border-color 0.3s; }

            .solution-card:hover {
                transition: transform 0.3s ease, box-shadow 0.3s ease;

                box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);
            }

            .solution-card:before {
                content: "";
                position: absolute;
                inset: 0;
                padding: 1px; /* border thickness */
                border-radius: 0.5rem;
                --angle: 270deg;
                background: conic-gradient( from var(--angle), transparent 0deg, transparent 300deg, var(--primary) 330deg, transparent 360deg );
                z-index: 0;
                opacity: 0;
                pointer-events: none;
                /* Keep only border */
                -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
            }

        @@property --angle {
            syntax: "<angle>";
            inherits: false;
            initial-value: 270deg;
        }

        .solution-card::after {
            content: "";
            position: absolute;
            inset: 2px;
            /* background: #fff; */
            border-radius: 0.5rem;
            z-index: 0;
        }

        .solution-card > * {
            position: relative;
            z-index: 2;
        }

        .solution-card:hover::before
        {
            opacity: 1;
            animation: snake-border 3.2s linear infinite;
        }

        @@keyframes snake-border {
            from {
                --angle: 270deg;
            }

            to {
                --angle: 630deg;
            }
        }

    .icon-box {
      width: 12rem; height: 3rem; border-radius: 0.5rem;
      display: flex; align-items: center; 
      color: var(--primary-color); margin-bottom: 1.5rem;
    }
    .icon-box svg { width: 1.5rem; height: 1.5rem; }

    .solution-card h3 { font-size: 1.25rem; font-weight: 700; color: var(--text-bright); margin-bottom: 0.75rem; }
    .solution-card .desc { color: var(--text-dim); margin-bottom: 1rem; }
    .solution-card .highlight { font-size: 0.875rem; color: var(--text-dim); font-style: italic; margin-bottom: 1.5rem; }
    .cap-label { font-size: 0.875rem; font-weight: 600; margin-bottom: 0.75rem; }
    .cap-list { list-style: none; }
    .cap-list li {
      display: flex; align-items: flex-start; gap: 0.625rem;
      font-size: 0.875rem; color: var(--text-dim); margin-bottom: 0.5rem;
    }
    .cap-list li svg { width: 1rem; height: 1rem; color: var(--primary-color); flex-shrink: 0; margin-top: 0.125rem; }

    /* ---- MID CTA ---- */
    .mid-cta {
      padding: 5rem 0;
      text-align: center;
      
    }
    .mid-cta h2 { font-size: clamp(1.5rem, 2.5vw, 2.25rem); font-weight: 700; color: var(--text-bright); margin-bottom: 1rem; text-wrap: balance; }
    .mid-cta p { font-size: 1.125rem; color: var(--text-dim); max-width: 40rem; margin: 0 auto 2rem; }

    /* ---- BENEFITS ---- */
    .benefits-grid { display: grid; gap: 1.5rem; }
    @@media (min-width: 640px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (min-width: 1024px) { .benefits-grid { grid-template-columns: repeat(3, 1fr); } }

    .benefit-card {
      display: flex; gap: 1.25rem; padding: 1.5rem;
      border-radius: var(--radius); border: 1px solid var(--border);
            background: rgba(250,250,250,0.5);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

            .benefit-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);
            }
    .benefit-card h3 { font-size: 1.125rem; font-weight: 600; color: var(--text-bright); margin-bottom: 0.5rem; }
    .benefit-card p { color: var(--text-dim); }

    /* ---- CASE STUDY ---- */
    
    .case-study { padding: 2rem; }
    @@media (min-width: 768px) { .case-study { padding: 3rem; } }
    @@media (min-width: 1024px) { .case-study { padding: 4rem; } }
    .case-study .label-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; }
    .case-study .label-row svg { width: 1.25rem; height: 1.25rem; color: var(--primary-color); }
    .case-study h2 { font-size: clamp(1.5rem, 2.5vw, 2.25rem); font-weight: 700; color: var(--text-bright); margin-bottom: 1.5rem; text-wrap: balance; }
    .case-study p { font-size: 1.125rem; color: var(--text-dim); max-width: 48rem; margin-bottom: 1rem; }


    /* ══════════════════════════════════════════════
   10. CTA
   ══════════════════════════════════════════════ */
.cta-section {
    background: var(--primary);
    text-align: center;
}

    .cta-section .inner {
        max-width: 48rem;
        margin: 0 auto;
    }

    .cta-section h2 {
        font-size: clamp(1.875rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        margin-bottom: 1.5rem;
        line-height: 1.15;
    }

    .cta-section p {
        font-size: 1.125rem;
        font-family: var(--font-body);
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 2.5rem;
        line-height: 1.7;
    }

    .cta-section .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }

    /* ---- DELIVERY STEPS ---- */
    .step-card {
      display: flex; gap: 1.5rem; padding: 1.5rem;
      border-radius: var(--radius); border: 1px solid var(--border);
      background: rgba(250,250,250,0.5); transition: border-color 0.3s;
      margin-bottom: 1rem;
    }
    @@media (min-width: 768px) { .step-card { gap: 2rem; padding: 2rem; } }
    .step-card:hover { border-color: hsla(var(--primarycss), 0.2); }

        .step-num {
            font-size: clamp(1.5rem, 2vw, 2.25rem);
            font-weight: 900;
            color: var(--primary);
            line-height: 1;
            flex-shrink: 0;
            padding-top: 0.25rem;
        }
    .step-card h3 { font-size: 1.125rem; font-weight: 600; color: var(--text-bright); margin-bottom: 0.5rem; }
    .step-card p { color: var(--text-dim); }

    /* ---- FINAL CTA ---- */
    .final-cta {
      padding: 5rem 0 7rem;
      text-align: center;
    }
    .final-cta h2 { font-size: clamp(1.5rem, 2.5vw, 2.25rem); font-weight: 700; color: var(--text-bright); margin-bottom: 1rem; text-wrap: balance; }
    .final-cta p { font-size: 1.125rem; color: var(--text-dim); max-width: 40rem; margin: 0 auto 2rem; }
    .final-cta .btn-group { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    
/* ===== CASE STUDY ===== */
.case-study{padding:5rem 0;}
.case-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius) ;box-shadow:0 0 20px -8px var(--primary-glow)}
.case-card .label-row{display:flex;align-items:center;gap:8px;margin-bottom:24px}
.case-card .label-row svg{width:20px;height:20px;stroke:var(--primary);fill:none;stroke-width:2}
.case-card h2{font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;letter-spacing:-0.01em;margin-bottom:24px}
.case-card p{font-size:1.125rem;color:var(--text-dim);max-width:720px;margin-bottom:32px}
.case-card { overflow: hidden; max-width: 760px; margin: 0 auto; }
    .case-bar { height: 8px; background: linear-gradient(90deg, hsl(228, 100%, 55%), hsl(228, 100%, 55%, 0.6)); }
    .case-body { padding: 2rem 3rem; }
    .case-body h3 { font-size: 1.5rem; font-weight: 600; margin: 1rem 0; }
    .case-body p { color: var(--muted); line-height: 1.7; margin-bottom: 2rem; }


.case-header { max-width: 640px; margin: 0 auto 4rem; text-align: center; }
    .case-header h2 { font-size: clamp(1.875rem, 4vw, 3rem); font-weight: 600; }
    .case-header p { margin-top: 1rem; color: var(--muted); font-size: 1.0625rem; }
    .arrow-icon { display: inline-block; width: 16px; height: 16px; }
    .badge {
      display: inline-block; padding: 0.25rem 0.75rem;
      background: var(--primary-10); color: var(--primary);
      border-radius: 9999px; font-size: 0.75rem; font-weight: 600;
      margin-bottom: 1rem;
    }

    .case-section{
        padding: 5rem 0;
    }

      .case-section .btn-link {
      display: inline-flex; align-items: center; gap: 0.5rem;
      color: var(--primary); font-size: 0.875rem; font-weight: 500;
      text-decoration: none; transition: opacity 0.2s;
    }
    .case-section .btn-link:hover { opacity: 0.8; }
    .case-section .card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--bg);
    transition: box-shadow 0.3s;
}
  </style>
}


