@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.CaseStudy>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}

@section Styles {
    <style>
        /* ── Page wrapper ── */
        .cs-page {
            padding: 0 0 6rem;
            background: var(--background);
        }

        /* ── Hero Banner ── */
        .cs-banner {
            position: relative;
            width: 100%;
            height: 480px;
            overflow: hidden;
        }

        @@media (max-width: 1400px) {
            .cs-banner {
                height: 380px;
            }
        }

        .cs-banner-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .cs-banner-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.55) 55%, rgba(0,0,0,0.15) 100%);
        }

        .cs-banner-content {
            position: absolute;
            bottom: 2.75rem;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
           
        }

        .cs-tag {
            display: inline-block;
            background: rgba(255,255,255,0.15);
            border: 1px solid rgba(255,255,255,0.3);
            color: #fff;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.875rem;
            backdrop-filter: blur(4px);
        }

        .cs-banner-title {
            font-size: clamp(1.4rem, 2.5vw, 2.25rem);
            font-weight: 700;
            color: #fff;
            line-height: 1.50;
            letter-spacing: -0.02em;
            margin-bottom: 0.75rem;
            font-family: var(--font-heading);
            
            
        }

        .cs-banner-sub {
            font-size: 1rem;
            color: rgba(255,255,255,0.8);
            line-height: 1.65;
            margin: 0;
            max-width: 560px;
        }

        @@media (max-width: 600px) {
            .cs-banner { height: 360px; }
            .cs-banner-content { bottom: 1.75rem; padding: 0 1.25rem; }
        }

        /* ── Two-column layout ── */
        .cs-layout {
            display: grid;
            grid-template-columns: 1fr 300px;
            gap: 3rem;
            align-items: start;
            margin-top: 3rem;
        }

        /* ── Main content ── */
        .cs-content h4 {
            font-size: 1.1rem;
            color: var(--foreground);
            margin: 2rem 0 0.6rem;
            font-family: var(--font-heading);
        }

        .cs-content h4:first-child {
            margin-top: 0;
        }

        .cs-content p {
            font-size: 0.9375rem;
            color: #737373;
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        .cs-content ul {
            list-style: none;
            margin: 0.25rem 0 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .cs-content ul li {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            font-size: 0.9375rem;
            color: #737373;
            line-height: 1.7;
        }

        .cs-content ul li::before {
            content: '';
            flex-shrink: 0;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #000;
            margin-top: 0.58rem;
        }

        .cs-content ul li strong {
            color: var(--foreground);
        }

        /* Nested list */
        .cs-content ul ul {
            margin: 0.4rem 0 0 1rem;
        }

        .cs-content ul ul li::before {
            background: var(--primary-20);
        }

        /* Section divider */
        .cs-section {
            padding-top: 1.75rem;
            margin-top: 1.75rem;
            border-top: 1px solid var(--border);
        }

        .cs-section:first-child {
            border-top: none;
            padding-top: 0;
            margin-top: 0;
        }

        /* Results highlight cards */
        .results-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin: 1rem 0 1.25rem;
        }

        .result-card {
            background: #f0f4ff;
            border: 1px solid rgba(27, 84, 255, 0.12);
            border-radius: 0.6rem;
            padding: 1.1rem 1.25rem;
        }

        .result-card .stat {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            font-family: var(--font-heading);
            line-height: 1;
            margin-bottom: 0.3rem;
        }

        .result-card p {
            font-size: 0.825rem;
            color: var(--muted);
            margin: 0;
            line-height: 1.4;
        }

        /* ── Sidebar ── */
        .cs-sidebar {
            position: sticky;
            top: 5rem;
        }

        .meta-box {
            background: var(--cool-grey);
            border-radius: 0.75rem;
            padding: 1.75rem;
            border: 1px solid var(--border);
        }

        .meta-box h3 {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 1.25rem;
        }

        .sidebar-item {
            padding: 0.9rem 0;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-item:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .sidebar-item .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--muted);
            margin-bottom: 0.3rem;
        }

        .sidebar-item .value {
            font-size: 0.875rem;
            color: var(--foreground);
            font-weight: 500;
            line-height: 1.5;
        }

        .tech-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.4rem;
            margin-top: 0.4rem;
        }

        .tech-tag {
            background: var(--primary-10);
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.25rem 0.65rem;
            border-radius: 2rem;
        }

        /* ── CTA Banner ── */
        .cs-cta-banner {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            border: 1px solid rgba(27, 84, 255, 0.15);
            border-radius: 0.75rem;
            padding: 1.25rem 2rem;
            display: inline-flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .cs-cta-banner p {
            font-size: 1rem;
            font-weight: 600;
            color: var(--foreground);
            margin: 0;
        }

        /* ── Responsive ── */
        @@media (max-width: 960px) {
            .cs-layout {
                grid-template-columns: 1fr;
            }

            .cs-sidebar {
                position: static;
            }

            .meta-box {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 0;
            }

            .meta-box h3 {
                grid-column: 1/-1;
            }

            .sidebar-item {
                border-bottom: none;
                border-right: 1px solid var(--border);
                padding-right: 1rem;
            }

            .sidebar-item:nth-child(even) {
                border-right: none;
                padding-left: 1rem;
            }
        }

        /* ── Solution cards ── */
        .solution-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1rem;
            margin: 1rem 0 1.25rem;
        }

        .solution-card {
            background: var(--cool-grey);
            border: 1px solid var(--border);
            border-radius: 0.6rem;
            padding: 1.25rem;
        }

        .solution-card h5 {
            font-size: 0.875rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .solution-card p {
            font-size: 0.825rem;
            color: var(--muted);
            margin: 0;
            line-height: 1.6;
        }

        /* ── Impact callout ── */
        .impact-text {
            background: #f0f4ff;
            border-left: 3px solid var(--primary);
            border-radius: 0 0.5rem 0.5rem 0;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
            font-size: 0.9375rem;
            color: #737373;
            line-height: 1.7;
        }

        @@media (max-width: 600px) {
            .results-grid {
                grid-template-columns: 1fr;
            }

            .cs-cta-banner {
                padding: 1.75rem;
                flex-direction: column;
                
            }

            .meta-box {
                grid-template-columns: 1fr;
            }

            .sidebar-item {
                border-right: none;
                padding-right: 0;
                padding-left: 0 !important;
                border-bottom: 1px solid var(--border);
            }

            .sidebar-item:last-child {
                border-bottom: none;
            }
        }
        
    </style>
}
  
    <!-- ═══ HERO BANNER ═══ -->
    <div class="cs-banner">
        <img src="/images/ragbig.png" alt="RAG365 AI Knowledge Retrieval" class="cs-banner-img" />
        <div class="cs-banner-overlay"></div>
        <div class="cs-banner-content container">
            <span class="cs-tag">Case Study</span>
            <h1 class="cs-banner-title">RAG365: Powered Knowledge Retrieval</h1>
        </div>
    </div>

    <!-- ═══ MAIN ═══ -->
    <main class="cs-page">
        <div class="container">
            <div class="cs-layout">

                <article class="cs-content">

                    <div class="cs-section">
                        <h4>Overview</h4>
                        <p>RAG365 was deployed for a large consultancy firm managing thousands of internal documents, contracts, and compliance memos. The goal was to replace time-consuming manual document searching with instant AI-powered question-answering-grounded exclusively in internal sources.</p>
                    </div>

                    <div class="cs-section">
                        <h4>Objectives</h4>
                        <ul>
                            <li>Eliminate manual document searching-replace time-consuming retrieval with instant AI-powered question-answering from internal sources.</li>
                            <li>Ensure answer reliability-provide only document-grounded responses with explicit source citations, preventing hallucination from external sources.</li>
                            <li>Enable real-time knowledge access-surface relevant intelligence instantly during live client meetings, shifting the firm from reactive to proactive.</li>
                        </ul>
                    </div>

                    <div class="cs-section">
                        <h4>Challenges</h4>
                        <ul>
                            <li>Thousands of scattered PDFs and contracts across multiple systems-no unified retrieval layer, no structure, and no searchability.</li>
                            <li>Significant daily time loss-consultants spent hours per day manually searching documents before client calls, pitches, and proposals.</li>
                            <li>Inconsistent information-different team members surfacing different or outdated answers, creating compliance and credibility risk.</li>
                            <li>Zero on-demand access-no way to query institutional knowledge during live client engagements without manual interruption.</li>
                        </ul>
                    </div>

                    <div class="cs-section">
                        <h4>Solutions</h4>
                        <p>RAG365 deployed a private Generative AI knowledge bot, purpose-built around the firm's internal document library:</p>
                        <div class="solution-cards">
                            <div class="solution-card">
                                <h5>Private Knowledge Index</h5>
                                <p>All internal PDFs, contracts and memos ingested into a secure, encrypted retrieval index-no public web access at any stage.</p>
                            </div>
                            <div class="solution-card">
                                <h5>Natural Language Querying</h5>
                                <p>Staff ask plain-language questions and receive precise, synthesised answers instantly.</p>
                            </div>
                            <div class="solution-card">
                                <h5>Source-Cited Responses</h5>
                                <p>Every answer references its source by name and Doc ID, enabling instant verification.</p>
                            </div>
                            <div class="solution-card">
                                <h5>Context-Aware Processing</h5>
                                <p>Tailored to the firm's industry vocabulary, contract formats, and internal naming conventions-not a generic AI model.</p>
                            </div>
                            <div class="solution-card">
                                <h5>Zero-Disruption Deployment</h5>
                                <p>Integrated without changing how documents are stored or how staff work-platform-agnostic by design.</p>
                            </div>
                        </div>
                    </div>

                    <div class="cs-section">
                        <h4>Impact</h4>
                        <div class="results-grid">
                            <div class="result-card">
                                <div class="stat">75%</div>
                                <p>Faster Retrieval-reduction in daily document search time per consultant</p>
                            </div>
                            <div class="result-card">
                                <div class="stat">0</div>
                                <p>Hallucinations-all answers grounded exclusively in internal documents</p>
                            </div>
                            <div class="result-card">
                                <div class="stat">24/7</div>
                                <p>Availability-real-time knowledge access during live client meetings</p>
                            </div>
                        </div>
                        <div class="impact-text">
                            <strong>Productivity Impact:</strong> The 75% reduction in search time represents a transformative reclaim of consultant-hours. Staff who previously spent 45–60 minutes per day hunting documents now access verified answers in seconds. At scale, this translates to hundreds of recovered working hours per week-reinvested directly into billable client work.
                        </div>
                        <div class="impact-text">
                            <strong>Strategic Impact:</strong> Real-time intelligence surfaced during live client meetings gave consultants an immediate competitive edge. Source-cited responses eliminated inconsistency risk, building internal trust in the system and confidence in all client-facing outputs.
                        </div>
                    </div>

                </article>

                <aside class="cs-sidebar">
                    <div class="meta-box">
                        <h3>Project Details</h3>
                        <div class="sidebar-item">
                            <div class="label">Product</div>
                            <div class="value">RAG365</div>
                        </div>
                        <div class="sidebar-item">
                            <div class="label">Sector</div>
                            <div class="value">Large Consultancy Firm</div>
                        </div>
                        <div class="sidebar-item">
                            <div class="label">Technology</div>
                            <div class="tech-tags">
                                <span class="tech-tag">RAG</span>
                                <span class="tech-tag">Generative AI</span>
                                <span class="tech-tag">Vector Search</span>
                                <span class="tech-tag">LLM</span>
                                <span class="tech-tag">Private AI</span>
                            </div>
                        </div>
                        <div class="sidebar-item">
                            <div class="label">Tagline</div>
                            <div class="value">Stop Searching. Start Asking.</div>
                        </div>
                    </div>
                </aside>

            </div>

            <div style="text-align:center;margin-top:2.5rem;">
                <div class="cs-cta-banner">
                    <p>What business challenges are you dealing with? We can help.</p>
                    <a href="/contact-us" class="btn btn-primary">Talk to an Expert</a>
                </div>
            </div>

        </div>
    </main>