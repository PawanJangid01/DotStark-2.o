@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.PrivacyPolicy>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}

@section Styles {
    <style>
        /* ── Breadcrumb ── */
        .breadcrumb-bar {
            background: var(--cool-grey);
            padding: 0.85rem 0;
            border-bottom: 1px solid var(--border);
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            list-style: none;
            font-size: 0.875rem;
            color: var(--muted);
        }

        .breadcrumb li+li::before {
            content: '/';
            margin-right: 0.5rem;
            color: var(--muted);
        }

        .breadcrumb a {
            color: var(--primary);
            transition: opacity 0.2s;
        }

        .breadcrumb a:hover {
            opacity: 0.75;
        }

        .breadcrumb .active {
            color: var(--foreground);
            font-weight: 500;
        }

        /* ── Hero ── */
        .pp-hero {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            padding: 5rem 0 4rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            border-bottom: 1px solid var(--border);
        }

        .pp-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(27, 84, 255, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .pp-hero h1 {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            color: var(--foreground);
            position: relative;
        }

        .pp-hero h1 span {
            color: var(--primary);
        }

        .pp-hero p {
            margin-top: 1rem;
            color: var(--muted);
            font-size: 1rem;
            position: relative;
        }
    </style>
    <style>
        /* ── Content layout ── */
        .pp-content {
            padding: 5rem 0 6rem;
            background: var(--background);
        }

        .pp-layout {
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 4rem;
            align-items: start;
        }

        /* Sidebar TOC */
        .pp-toc {
            position: sticky;
            top: 5rem;
        }

        .pp-toc h3 {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 1rem;
        }

        .pp-toc ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .pp-toc a {
            display: block;
            padding: 0.4rem 0.75rem;
            font-size: 0.875rem;
            color: var(--muted);
            border-left: 2px solid var(--border);
            transition: color 0.2s, border-color 0.2s;
        }

        .pp-toc a:hover,
        .pp-toc a.active {
            color: var(--primary);
            border-left-color: var(--primary);
        }

        /* Body text */
        .pp-body {
            min-width: 0;
        }

        .pp-body p {
            font-size: 0.9375rem;
            color: #444;
            line-height: 1.8;
            margin-bottom: 1.25rem;
        }

        .pp-body h2 {
            font-size: 1.35rem;
            color: var(--foreground);
            margin: 2.5rem 0 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--primary-10);
            scroll-margin-top: 5rem;
        }

        .pp-body h2 .section-num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 1.75rem;
            height: 1.75rem;
            background: var(--primary);
            color: #fff;
            border-radius: 50%;
            font-size: 0.75rem;
            font-weight: 700;
            margin-right: 0.6rem;
            vertical-align: middle;
        }

        .pp-body h3 {
            font-size: 1.05rem;
            color: var(--foreground);
            margin: 1.75rem 0 0.5rem;
        }

        .pp-body h4 {
            font-size: 0.95rem;
            color: var(--foreground);
            margin: 1.25rem 0 0.4rem;
            font-weight: 600;
        }

        .pp-body ul {
            list-style: none;
            margin: 0.5rem 0 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .pp-body ul li {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            font-size: 0.9375rem;
            color: #444;
            line-height: 1.7;
        }

        .pp-body ul li::before {
            content: '';
            flex-shrink: 0;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: #000000;
            margin-top: 0.55rem;
        }

        .pp-body ul li strong {
            color: var(--foreground);
        }

        .pp-body a {
            
            text-decoration: none;
        }

        /* Intro card */
        .pp-intro-card {
            background: #f0f4ff;
            border-radius: 0.75rem;
            padding: 2rem 2.25rem;
            margin-bottom: 2.5rem;
            border-left: 4px solid var(--primary);
        }

        .pp-intro-card p {
            color: #444;
            margin-bottom: 0;
        }

        .pp-intro-card p+p {
            margin-top: 0.75rem;
        }

        /* Meta badges */
        .pp-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 2.5rem;
            flex-wrap: wrap;
        }

        .pp-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--primary-10);
            color: var(--primary);
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.35rem 0.85rem;
            border-radius: 2rem;
        }

        .pp-badge svg {
            flex-shrink: 0;
        }

        /* Cookie type blocks */
        .cookie-block {
            background: var(--cool-grey);
            border-radius: 0.5rem;
            padding: 1.25rem 1.5rem;
            margin: 0.75rem 0;
        }

        .cookie-block strong {
            color: var(--foreground);
            display: block;
            margin-bottom: 0.4rem;
        }

        .cookie-block p {
            margin-bottom: 0.3rem;
            font-size: 0.875rem;
        }

        .cookie-block p:last-child {
            margin-bottom: 0;
        }

        /* Contact CTA */
        .pp-contact-cta {
            margin-top: 3rem;
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            border-radius: 0.75rem;
            padding: 2.5rem;
            text-align: center;
            border: 1px solid rgba(27, 84, 255, 0.15);



        }

        .pp-contact-cta h3 {
            color: var(--foreground);
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .pp-contact-cta p {
            color: var(--muted);
            margin-bottom: 1.5rem;
        }

        /* Responsive */
        @@media (max-width: 900px) {
            .pp-layout {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .pp-toc {
                position: static;
                background: var(--cool-grey);
                border-radius: 0.5rem;
                padding: 1.25rem 1.5rem;
            }

            .pp-toc ul {
                flex-direction: row;
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            .pp-toc a {
                border-left: none;
                border-bottom: 2px solid var(--border);
                padding: 0.3rem 0.5rem;
            }

            .pp-toc a:hover,
            .pp-toc a.active {
                border-bottom-color: var(--primary);
                border-left-color: transparent;
            }
        }

        @@media (max-width: 600px) {
            .pp-hero {
                padding: 3.5rem 0 3rem;
            }

            .pp-content {
                padding: 3rem 0 4rem;
            }

            .pp-intro-card {
                padding: 1.5rem;
            }
        }
    </style>
    }


    <!-- ═══ CONTENT ═══ -->
    <main class="pp-content">
        <div class="container">
            <div class="pp-layout">

                <!-- Sidebar TOC -->
                <aside class="pp-toc" aria-label="Table of contents">
                    <h3>On this page</h3>
                    <ul>
                        <li><a href="#who-we-are">Who We Are</a></li>
                        <li><a href="#what-we-collect">What We Collect</a></li>
                        <li><a href="#how-we-use">How We Use It</a></li>
                        <li><a href="#sharing">Do We Share Data?</a></li>
                        <li><a href="#ai-data">AI &amp; Your Data</a></li>
                        <li><a href="#cookies">Cookies</a></li>
                        <li><a href="#retention">How Long We Keep It</a></li>
                        <li><a href="#your-rights">Your Rights</a></li>
                        <li><a href="#security">Data Security</a></li>
                        <li><a href="#children">Children</a></li>
                        <li><a href="#changes">Changes</a></li>
                        <li><a href="#contact">Contact Us</a></li>
                    </ul>
                </aside>

                <!-- Body -->
                <article class="pp-body">

                    <div class="pp-meta">
                        <span class="pp-badge">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="4" width="18" height="18" rx="2" />
                                <line x1="16" y1="2" x2="16" y2="6" />
                                <line x1="8" y1="2" x2="8" y2="6" />
                                <line x1="3" y1="10" x2="21" y2="10" />
                            </svg>
                            Last updated: March 2025
                        </span>
                        <span class="pp-badge">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                            </svg>
                            GDPR Compliant
                        </span>
                    </div>

                    <div class="pp-intro-card" id="intro">
                        <p>This Privacy Policy describes how DS2.0, an AI services company and sister company of DotStark Technologies, collects, uses, and protects your information when you use our services.</p>
                        <p>By using our services, you agree to the collection and use of information in accordance with this Privacy Policy.</p>
                    </div>

                    <h2 id="who-we-are"><span class="section-num">1</span>Who We Are</h2>
                    <p>DS2.0 is an AI services company and a sister company of DotStark Technologies. We build artificial intelligence solutions for businesses worldwide.</p>

                    <h2 id="what-we-collect"><span class="section-num">2</span>What Information We Collect</h2>
                    <ul>
                        <li>Your name, email, phone number, and company name</li>
                        <li>Billing and payment details</li>
                        <li>How you use our website and services</li>
                        <li>Messages and emails you send us</li>
                        <li>Data you submit through our AI tools</li>
                    </ul>

                    <h2 id="how-we-use"><span class="section-num">3</span>How We Use Your Information</h2>
                    <ul>
                        <li>To deliver and improve our AI services</li>
                        <li>To process payments and send invoices</li>
                        <li>To respond to your questions and support requests</li>
                        <li>To send service updates and important notices</li>
                        <li>To keep our platform secure and fix issues</li>
                    </ul>

                    <h2 id="sharing"><span class="section-num">4</span>Do We Share Your Data?</h2>
                    <p>We do not sell your personal data. We only share it with:</p>
                    <ul>
                        <li>Trusted vendors who help us run our services (e.g. cloud hosting, payments)</li>
                        <li>DotStark Technologies for internal operations</li>
                        <li>Authorities if required by law</li>
                    </ul>

                    <h2 id="ai-data"><span class="section-num">5</span>AI &amp; Your Data</h2>
                    <p>When you use our AI tools, your inputs and outputs are processed to deliver results. We do not use your data to train our AI models unless you give us explicit permission.</p>

                    <h2 id="cookies"><span class="section-num">6</span>Cookies</h2>
                    <p>We use cookies to keep you logged in, remember your preferences, and understand how people use our site. You can disable cookies in your browser settings.</p>
                    <div class="cookie-block">
                        <strong>Essential Cookies</strong>
                        <p>Required to keep you logged in and use core features of the platform.</p>
                    </div>
                    <div class="cookie-block">
                        <strong>Preference Cookies</strong>
                        <p>Remember your settings and preferences for a better experience.</p>
                    </div>
                    <div class="cookie-block">
                        <strong>Analytics Cookies</strong>
                        <p>Help us understand how visitors use our site so we can improve it.</p>
                    </div>

                    <h2 id="retention"><span class="section-num">7</span>How Long We Keep Your Data</h2>
                    <ul>
                        <li><strong>Account information</strong> — 2 years after you close your account</li>
                        <li><strong>AI interaction data</strong> — 90 days by default, then deleted</li>
                        <li><strong>Billing records</strong> — 7 years (legal requirement)</li>
                        <li><strong>Support messages</strong> — 3 years</li>
                    </ul>

                    <h2 id="your-rights"><span class="section-num">8</span>Your Rights</h2>
                    <p>You have the right to:</p>
                    <ul>
                        <li>See the data we hold about you</li>
                        <li>Correct any inaccurate information</li>
                        <li>Ask us to delete your data</li>
                        <li>Opt out of marketing emails at any time</li>
                    </ul>
                    <p>To exercise any of these rights, email us at <a href="mailto:privacy@ds2.ai">privacy@ds2.ai</a>.</p>

                    <h2 id="security"><span class="section-num">9</span>Data Security</h2>
                    <p>We use encryption, secure servers, and strict access controls to protect your data. If a breach occurs, we will notify affected users within 72 hours.</p>

                    <h2 id="children"><span class="section-num">10</span>Children</h2>
                    <p>Our services are not intended for anyone under 18 years of age. We do not knowingly collect data from minors.</p>

                    <h2 id="changes"><span class="section-num">11</span>Changes to This Policy</h2>
                    <p>We may update this policy occasionally. We will notify you by email or on our website if we make significant changes.</p>

                    <h2 id="contact"><span class="section-num">12</span>Contact Us</h2>
                    <div class="pp-contact-cta">
                        <h3>Have a privacy question?</h3>
                        <p>We will respond to all privacy inquiries within 5 business days.</p>
                        <ul style="display:inline-flex;flex-direction:column;gap:0.5rem;text-align:left;margin-bottom:1.5rem;">
                            <li>Email: <a href="mailto:privacy@ds2.ai">privacy@ds2.ai</a></li>
                            <li>Phone: +91 (0) 141 000 0000</li>
                            <li>Address: Jaipur, Rajasthan, India</li>
                        </ul>
                        <br/>
                        <a href="mailto:privacy@ds2.ai" class="btn btn-primary">Email Us</a>
                    </div>

                </article>
            </div>
        </div>
    </main>

    <script>
        // TOC active highlight
        const sections = document.querySelectorAll('.pp-body h2[id], #intro');
        const tocLinks = document.querySelectorAll('.pp-toc a');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    tocLinks.forEach(link => {
                        link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
                    });
                }
            });
        }, { rootMargin: '-20% 0px -70% 0px' });
        sections.forEach(s => observer.observe(s));
    </script>