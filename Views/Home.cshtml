@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Home>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}

    @section Styles {
        <style>
/* ══════════════════════════════════════════════
   1. HERO
   ══════════════════════════════════════════════ */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--background);
    overflow: hidden;
    padding: 80px 0 5rem 0;
}

/* VIDEO */
.hero-video {
    position: absolute;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* CONTENT ABOVE VIDEO */
.hero .container {
    position: relative;
    z-index: 2;
}

    .hero .grid-pattern {
        position: absolute;
        inset: 0;
        opacity: 0.03;
        background-image: radial-gradient(#111 1px, transparent 1px);
        background-size: 40px 40px;
    }

    .hero .hero-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
        align-items: center;
    }

@@media (min-width: 1024px) {
    .hero .hero-grid {
        grid-template-columns: 1fr 1fr;
    }
}

.hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 1.5rem;
}
@@media (min-width: 1024px) and (max-width: 1400px) {
    .hero h1 {
        font-size: clamp(2.25rem, 5vw, 2.75rem);
    }
}

    .hero h1 span {
        color: var(--primary);
    }

.hero .subtitle {
    font-size: clamp(1.125rem, 2vw, 1.25rem);
    font-family: var(--font-body);
    color: var(--muted);
    max-width: 36rem;
    margin-bottom: 2.5rem;
    line-height: 1.7;
}

.hero .btn-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
}

.ai-viz-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
}

.ai-viz {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    aspect-ratio: 1;
}

    .ai-viz svg {
        width: 100%;
        height: 100%;
    }

    .ai-viz .float-card {
        position: absolute;
        padding: 0.5rem 1rem;
        background: var(--background);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        font-size: 0.75rem;
        font-family: var(--font-body);
        color: var(--muted);
        animation: float 4s ease-in-out infinite;
        white-space: nowrap;
    }

        .ai-viz .float-card.top-right {
            top: 2rem;
            right: 0;
        }

        .ai-viz .float-card.bottom-left {
            bottom: 4rem;
            left: 0;
            animation-delay: 1s;
            animation-direction: reverse;
        }

@@keyframes float {

    0%, 100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-8px);
    }
}

        .testi-left svg {
            margin-left: 2.3rem;
        }

@@media (max-width: 1023px) {
    .ai-viz-wrapper {
        display: none;
    }
}

        @@media (max-width: 992px) {
            .testi-left svg {
                margin-left: 2rem;
                margin-bottom: 30px;
            }
        }

        @@media (max-width: 567px) {
            .hero-video {
                display: none;
            }

            .testi-slide blockquote {             
                min-height: 160px !;
            }
        }
        @@media (max-width: 498px) {
            .testi-left svg {
                margin-left: 3rem;
               
            }

            .testi-slider-wrap{
                gap: 0.3rem;
            }
        }
/* ══════════════════════════════════════════════
   2. TRUST
   ══════════════════════════════════════════════ */

/* ══════════════════════════════════════════════
   3. SERVICES
   ══════════════════════════════════════════════ */
.services {
    background: var(--background);
}

    .services .services-header {
        max-width: 40rem;
        margin-bottom: 5rem;
    }

        .services .services-header h2 {
            font-size: clamp(1.875rem, 4vw, 3rem);
            font-weight: 700;
            color: var(--foreground);
            margin-bottom: 1.5rem;
        }

        .services .services-header p {
            font-size: 1.125rem;
            font-family: var(--font-body);
            color: var(--muted);
            line-height: 1.7;
        }

    .services .services-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
    }

@@media (min-width: 768px) {
    .services .services-grid {
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
    }
}

.service-block {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
}

    .service-block h3 {
        font-size: clamp(1.5rem, 3vw, 1.875rem);
        font-weight: 700;
        color: var(--foreground);
        margin-bottom: 0.75rem;
    }

    .service-block > p {
        font-family: var(--font-body);
        color: var(--muted);
        margin-bottom: 2rem;
    }

    .service-block ul {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .service-block li {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        font-family: var(--font-body);
        font-size: 1rem;
        color: var(--foreground);
    }

        .service-block li .dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--primary);
            flex-shrink: 0;
            margin-top: 0.55rem;
        }

/* ══════════════════════════════════════════════
   4. INNOVATION (dark)
   ══════════════════════════════════════════════ */
.innovation {
    background: var(--void);
    position: relative;
    overflow: hidden;
}

    .innovation .dot-pattern {
        position: absolute;
        inset: 0;
        opacity: 0.05;
        background-image: radial-gradient(var(--primary) 1px, transparent 1px);
        background-size: 30px 30px;
    }

    .innovation .container {
        position: relative;
        z-index: 1;
    }

    .innovation .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 4rem;
        align-items: center;
    }

@@media (min-width: 1024px) {
    .innovation .grid {
        grid-template-columns: 1fr 1fr;
    }
}

.innovation h2 {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 1.5rem;
    line-height: 1.15;
}

.innovation > .container p {
    font-size: 1.125rem;
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    margin-bottom: 2.5rem;
}

.innovation .example-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.innovation .example-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: var(--radius);
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.05);
}

.innovation .example-num {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--primary-20);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    font-size: 0.875rem;
    font-family: var(--font-heading);
    font-weight: 700;
    flex-shrink: 0;
}

.innovation .example-item span:last-child {
    font-family: var(--font-body);
    color: rgba(255, 255, 255, 0.9);
}

/* ══════════════════════════════════════════════
   5. SOLUTIONS
   ══════════════════════════════════════════════ */
.solutions {
    background: var(--background);
    padding:5rem 0;
}

    .solutions .solutions-header {
        max-width: 40rem;
        margin-bottom: 4rem;
    }

        .solutions .solutions-header h2 {
            font-size: clamp(1.875rem, 4vw, 3rem);
            font-weight: 700;
            color: var(--foreground);
        }

    .solutions .cards-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

@@media (min-width: 640px) {
    .solutions .cards-grid {
        grid-template-columns: 1fr 1fr;
    }
}

@@media (min-width: 1024px) {
    .solutions .cards-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

.solution-card {
    padding: 2rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: border-color 0.2s;
    cursor: pointer;
    background-color: #ebebec59;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
}
       

    .solution-card:hover
    {             
            transform: translateY(-5px);
            box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);       
    }

        .solution-card:before{
            content: "";
            position: absolute;
            inset: 0;
            padding: 1px; /* border thickness */
            border-radius: 0.5rem;
            --angle: 270deg;
                background: conic-gradient( from var(--angle), transparent 0deg, transparent 300deg, var(--primary) 330deg, transparent 360deg );
            z-index: 0;
            opacity: 0;
            pointer-events: none;
            /* Keep only border */
            -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
        }

        @@property --angle {
            syntax: "<angle>";
            inherits: false;
            initial-value: 270deg;
        }
            .solution-card::after
        {
            content: "";
            position: absolute;
            inset: 2px;
            /* background: #fff; */
            border-radius: 0.5rem;
            z-index: 0;
        }

            .solution-card > * {
            position: relative;
            z-index: 2;
        }

            .solution-card:hover::before
         {
            opacity: 1;
            animation: snake-border 3.2s linear infinite;
        }

        @@keyframes snake-border {
            from

        {
            --angle: 270deg;
        }

        to {
            --angle: 630deg;
        }

        }


    .solution-card .card-top {
        margin-bottom: 1rem;
    }

    .solution-card h3 {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--foreground);
    }

    .solution-card p {
        font-family: var(--font-body);
        color: var(--muted);
        line-height: 1.7;
    }

/* ══════════════════════════════════════════════
   6. PROCESS
   ══════════════════════════════════════════════ */
.process {
    background: #f8faff;
    padding:5rem 0;
}

    .process .process-header {
        max-width: 48rem;
        margin-bottom: 4rem;
    }

        .process .process-header h2 {
            font-size: clamp(1.875rem, 4vw, 3rem);
            font-weight: 700;
            color: var(--foreground);
            margin-bottom: 0.75rem;
        }

.process-subtext {
    font-family: var(--font-body);
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
}

.process .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

@@media (min-width: 768px) {
    .process .steps-grid {
        grid-template-columns: repeat(4, 1fr);
    }
}

/* Step card */
.step-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1.2rem 1.5rem;
    position: relative;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    overflow: hidden;
}

    /* .step-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--primary);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
    } */

    .step-card:hover {
        border-color: var(--primary-30);
        box-shadow: 0 8px 28px rgba(27, 84, 255, 0.1);
        transform: translateY(-4px);
    }

        .step-card:hover::before {
            transform: scaleX(1);
        }

.step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: var(--font-heading);
    margin-bottom: 1.25rem;
}

.step-icon {
    color: var(--primary);
    margin-bottom: 1rem;
}

.step-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 0.5rem;
}

.step-card p {
    font-family: var(--font-body);
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.95rem;
}

/* ══════════════════════════════════════════════
   7. CASE STUDIES
   ══════════════════════════════════════════════ */
.case-studies {
    background: var(--background);
    padding: 0 0 5rem 0;
}

    .case-studies .section-top {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

@@media (min-width: 768px) {
    .case-studies .section-top {
        flex-direction: row;
        align-items: flex-end;
        justify-content: space-between;
    }
}

.case-studies .section-top h2 {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--foreground);
}

.case-studies .link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-family: var(--font-body);
    font-weight: 500;
    transition: text-decoration 0.2s;
}

    .case-studies .link:hover {
        text-decoration: auto;
    }

.case-studies .cases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

@@media (min-width: 768px) {
    .case-studies .cases-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

.case-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s;
    cursor: pointer;
            height: -webkit-fill-available;
}

    .case-card:hover {
        border-color: var(--primary-30);
    }

    .case-image {
  width: 100%;
  height: 220px; /* same as your placeholder height */
  overflow: hidden;
  border-top-left-radius: var(--radius);
            border-top-right-radius: var(--radius);
}

.case-image img {
  width: 100%;
  height: 100%;
  object-fit: cover; /* prevents stretching */
  display: block;
}

    .case-card .image-placeholder {
        height: 12rem;
        background: var(--cool-grey);
        display: flex;
        align-items: center;
        justify-content: center;
        color: rgba(115, 115, 115, 0.3);
        font-family: var(--font-heading);
        font-size: 0.875rem;
    }

    .case-card .card-body {
        padding: 1.5rem;
            background-color: #ebebec59;
            height: -webkit-fill-available;
    }

    .case-card h3 {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--foreground);
        margin-bottom: 0.5rem;
    }

    .case-card p {
        font-family: var(--font-body);
        color: var(--muted);
        font-size: 0.875rem;
    }

/* ══════════════════════════════════════════════
   8. TESTIMONIALS
   ══════════════════════════════════════════════ */
.testimonials {
    background: var(--cool-grey);
    overflow: hidden;
}

/* Centered heading above the grid */
.testi-heading {
    text-align: center;
    margin-bottom: 3.5rem;
}

    .testi-heading h2 {
        font-size: clamp(1.75rem, 3.5vw, 2.5rem);
        font-weight: 700;
        color: var(--foreground);
        margin-top: 0.5rem;
    }

/* Equal 50/50 grid, equal height columns */
.testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: stretch;
}

/* ── LEFT ── */
.testi-left {
    display: flex;
    flex-direction: column;
}

/* Slider wrapper with arrows flanking */
.testi-slider-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 1;
}

/* Arrow buttons */
.testi-arrow {
    width: auto;
    height: auto;
    border: none;          /* remove border */
    background: transparent; /* remove background */
    border-radius: 0;      /* remove circle */
    padding: 0;
    
    font-size: 2rem;       /* increase arrow size */
    color: var(--primary);
    
    display: flex;
    align-items: center;
    justify-content: center;
    cursor:pointer;
}

/* Slider container */
.testi-slider {
    flex: 1;
    position: relative;
    /* min-height: 280px; */
    overflow: hidden;
}

/* Each slide stacked; only .active is visible */
.testi-slide {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
}

    .testi-slide.active {
        opacity: 1;
        transform: translateX(0);
        pointer-events: auto;
        position: relative;
    }

            .testi-slide blockquote {
                border-right: 2px solid transparent;
                min-height:90px;
            }

        .typing {
            border-right: 2px solid #000;
            white-space: normal;
        }
.testi-quote-icon {
    width: 48px;
    height: 36px;
    color: var(--primary);
    flex-shrink: 0;
}

.testi-slide blockquote {
    font-size: 1.05rem;
    color: #333;
    line-height: 1.75;
    font-style: italic;
    margin: 0;
            
}
        

.testi-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
}

.testi-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid var(--primary-20);
}

.testi-avatar.initials {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary);
    color: #fff;
    font-weight: 700;
    font-size: 1.6rem;
    text-transform: uppercase;
}

    .testi-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

.testi-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--foreground);
    margin: 0 0 0.15rem;
}

.testi-role {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
}

/* ── RIGHT ── */
.testi-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.testi-featured-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--primary);
}

.testi-video-wrap {
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(27, 84, 255, 0.15);
    aspect-ratio: 16 / 9;
    background: #000;
    flex: 1;
}

.testi-video-thumb {
    position: relative;
    width: 100%;
    height: 100%;
}

    .testi-video-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

.testi-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, transparent 55%);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem 1.5rem;
}

.testi-name-badge strong {
    display: block;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.2;
}

.testi-name-badge span {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.78rem;
}

.testi-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--primary);
    border: none;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(27, 84, 255, 0.4);
    transition: transform 0.2s, box-shadow 0.2s;
}

    .testi-play-btn:hover {
        transform: translate(-50%, -50%) scale(1.1);
        box-shadow: 0 6px 28px rgba(27, 84, 255, 0.55);
    }

    .testi-play-btn svg {
        margin-left: 4px;
    }

@@media (max-width: 900px) {
    .testimonials-grid {
        grid-template-columns: 1fr;
        gap: 3rem;
    }

    .testi-slider {
        min-height: 240px;
    }
}

@@media (max-width: 480px) {
    .testi-play-btn {
        width: 52px;
        height: 52px;
    }

    .testi-slide blockquote {
        font-size: 0.95rem;
        min-height:160px;
    }

    .testi-arrow {
        width: 36px;
        height: 36px;
        font-size: 1.3rem;
    }
}

/* ══════════════════════════════════════════════
   9. INSIGHTS
   ══════════════════════════════════════════════ */
.insights {
    background: var(--background);
    padding:0  0;
}

    .insights .section-top {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 4rem;
    }

@@media (min-width: 768px) {
    .insights .section-top {
        flex-direction: row;
        align-items: flex-end;
        justify-content: space-between;
    }
}

.insights .section-top h2 {
    font-size: clamp(1.875rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--foreground);
}

.insights .link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-family: var(--font-body);
    font-weight: 500;
}

    .insights .link:hover {
        text-decoration: underline;
    }

.insights .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

