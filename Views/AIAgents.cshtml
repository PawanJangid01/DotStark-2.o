        .agent-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 32px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            display: flex;
            flex-direction: column
        }

        .agent-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);
        }

        .agent-card:before {
            content: "";
            position: absolute;
            inset: 0;
            padding: 1px; /* border thickness */
            border-radius: 0.5rem;
            --angle: 270deg;
            background: conic-gradient( from var(--angle), transparent 0deg, transparent 300deg, var(--primary) 330deg, transparent 360deg );
            z-index: 0;
            opacity: 0;
            pointer-events: none;
            /* Keep only border */
            -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
        }

        @@property --angle {
            syntax: "<angle>";
            inherits: false;
            initial-value: 270deg;
        }

        .agent-card::after {
            content: "";
            position: absolute;
            inset: 2px;
            /* background: #fff; */
            border-radius: 0.5rem;
            z-index: 0;
        }

        .agent-card > * {
            position: relative;
            z-index: 2;
        }

        .agent-card:hover::before {
            opacity: 1;
            animation: snake-border 3.2s linear infinite;
        }

        @@keyframes snake-border {
            from {
                --angle: 270deg;
            }

            to {
                --angle: 630deg;
            }
        }
.agent-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;margin-bottom:24px;color:var(--primary)}
