            align-items: center;
            gap: 8px;
            font-family: inherit;
            font-weight: 600;
            padding: 0.6rem 1.4rem;
            font-size: 14px;
            border-radius: var(--radius);
            border: none;
            cursor: pointer;
            transition: all 0.25s cubic-bezier(0.16,1,0.3,1)
        }
.btn:active{transform:scale(0.97)}
.btn-primary{background:var(--primary);color:#fff;box-shadow:0 0 24px -4px var(--primary-glow)}
.btn-primary:hover{background:var(--primary-light);box-shadow:0 0 32px -4px rgba(27,84,255,0.5)}
.btn-outline{background:transparent;color:var(--text);border:1.5px solid rgba(27,84,255,0.4)}
