    <script>

document.addEventListener("DOMContentLoaded", function () {

    const plan = sessionStorage.getItem("selectedPlan");
    const product = sessionStorage.getItem("selectedProduct");

    const subscriptionHidden = document.getElementById("subscriptionHidden");
    const productHidden = document.getElementById("productHidden");

    if (plan && subscriptionHidden) {
        subscriptionHidden.value = plan;
    }

    if (product && productHidden) {
        productHidden.value = product;
    }

    sessionStorage.removeItem("selectedPlan");
    sessionStorage.removeItem("selectedProduct");

});


    function handleSubmit(e) {
    e.preventDefault();

    let isValid = true;

    const fields = [
            { name:"name", message:"Full Name is required"},
            { name:"email", message:"Email is required"},
            { name:"companyname", message:"Company name is required"},
            { name:"companySize", message:"Select company size"},
            { name:"subject", message:"Job role is required"},
    ];

    // Clear previous errors
    document.querySelectorAll(".error-message").forEach(el => el.remove());

    fields.forEach(field => {
        const input = document.querySelector(`[name="${field.name}"]`);

        if (!input || input.value.trim() === "") {
            showError(input, field.message);
            isValid = false;
        }

        // Email format validation
        if (field.name === "email" && input.value.trim() !== "") {
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

            if (!emailRegex.test(input.value.trim())) {
                showError(input, "Please enter a valid email address");
                isValid = false;
            }
        }
    });

    if (isValid) {
        document.getElementById('successMsg').classList.add('show');
        document.getElementById('contactForm').reset();

        setTimeout(() => {
            document.getElementById('successMsg').classList.remove('show');
        }, 5000);
    }
}

function showError(input, message) {
    const error = document.createElement("div");
    error.className = "error-message";   
    error.style.marginTop = "4px";
    error.innerText = message;

    input.parentNode.appendChild(error);
}
</script>