@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ContactUs>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}

@section Styles {
    <style>
        /* ===== Contact Hero Scoped ===== */

        .section {
            padding: 96px 0;
        }

        .section-alt {
            background: var(--secondary-bg);
        }

        .text-accent {
            color: var(--primary);
        }

        .contact-hero {
            position: relative;
            min-height: 70vh;
            display: flex;
            align-items: center;
            padding-top: 80px;
            overflow: hidden;
        }

        .contact-hero .hero-grid-bg {
            position: absolute;
            inset: 0;
            opacity: 0.03;
            background-image: radial-gradient(var(--foreground) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        .contact-hero .hero-content {
            position: relative;
            z-index: 2;
            max-width: 720px;
            text-align: center;
        }

        .contact-hero h1 {
            font-family: var(--font-heading);
            font-size: clamp(2.25rem, 5vw, 3.75rem);
            font-weight: 700;
            margin-bottom: 24px;
        }

        .contact-hero .subtitle {
            font-size: 1.125rem;
            color: var(--muted);
            max-width: 560px;
            margin: auto;
        }

        /* ===== Contact Form ===== */
        .contact-section .split-grid h2 {
            font-size: clamp(1.75rem, 4vw, 2.5rem);
            margin-bottom: 16px;
        }

        .contact-section .form-intro {
            color: var(--muted);
            margin-bottom: 40px;
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            resize: vertical;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(27, 84, 255, 0.15);
        }

        /* ===== Office ===== */
        .office-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .office-card {
            position: relative;
            padding: 20px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            background: var(--secondary-bg);
        }

        .flag-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 42px;
            height: 28px;
            object-fit: cover;
        }

        /* ===== Responsive ===== */
        .split-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 64px;
        }

        @@media (max-width: 1023px) {
            .split-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<!-- Hero -->
<section class="hero section-alt contact-hero">
  <div class="hero-grid-bg"></div>
  <div class="container hero-content fade-up">
    <h1>Let's Build the Future with <span class="text-accent">AI</span></h1>
    <p class="subtitle m-auto">Connect with our experts to explore AI-driven transformation.</p>
  </div>
</section>

  <!-- Contact Form + Global Presence -->
  <section class="section contact-section">
    <div class="container">
      <div class="split-grid">
        <!-- Form -->
        <div class="fade-up">
          <h2>Let’s Connect and Build Together</h2>
          <p class="form-intro">Fill in the form below and our team will get back to you within 24 hours.</p>

          <div class="form-success" id="formSuccess" style="display:none;">
            Thank you for reaching out! We'll be in touch soon.
          </div>

         @using (Html.BeginUmbracoForm("SubmitForm", "Form", FormMethod.Post, new { id = "contactForm", @class = "contact-form" }))
{
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required maxlength="100" placeholder="Your full name" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required maxlength="255" placeholder="you@email.com" />
            </div>
            <div class="form-group">
              <label for="company">Company</label>
              <input type="text" id="company" name="company" maxlength="100" placeholder="Your company name" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" required maxlength="1000" rows="2" placeholder="Tell us about your project..."></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-submit">
              Send Message
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.536 21.686a.5.5 0 0 0 .937-.024l6.5-19a.496.496 0 0 0-.635-.635l-19 6.5a.5.5 0 0 0-.024.937l7.93 3.18a2 2 0 0 1 1.112 1.11z"/><path d="m21.854 2.147-10.94 10.939"/></svg>
            </button>
       }
        </div>

        <!-- Global Presence -->
        <div class="fade-up">
          <h2>Global Presence</h2>
          <p class="form-intro">We operate across multiple regions, delivering AI and digital solutions worldwide.</p>

          <div class="office-grid">
           <div class="office-card fade-up">
               <img src="/images/india.png" class="flag-badge" />
             <h3>India</h3>
                <p>1st Floor, Opp. Metro Pillar No. 97, New Sanganer Road,<br>
                Jaipur - 302019 Rajasthan, India.</p>
                <p><strong>Contact:</strong> +91 9680599916</p>
                <p>support@dotstark.com</p>
           </div>
         
           <div class="office-card fade-up">
                <img src="/images/USA.webp" class="flag-badge" />
             <h3>USA</h3>
             <p>3101 N. Central Ave,<br>
              STE 183#3541, Phoenix, Arizona</p>
              <p><strong>Contact:</strong> +1 (602) 403-9958</p>
           </div>
         
           <div class="office-card fade-up" >
               <img src="/images/Canada.jpg" class="flag-badge" />
             <h3>Canada</h3>
             <p>26 Finch Crescent, London ON<br>
             N6E 2E5, Canada</p>
             <p><strong>Contact:</strong> +1 (647) 862-2190</p>
           </div>
         
           <div class="office-card fade-up" >
                <img src="/images/Malaysia.png" class="flag-badge" />
             <h3>Malaysia</h3>
                   <p>Plaza 33, No.1, Jalan Kemajuan,<br>
                  Seksyen 13, 46200,<br>
                  Petaling Jaya, Selangor, Malaysia</p>
                  <p><strong>Contact:</strong> +60 17-656 4127</p>
           </div>
         </div>
        </div>
      </div>
    </div>
  </section>