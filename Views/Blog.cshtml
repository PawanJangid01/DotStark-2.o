@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Blog>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}
@section Styles {
    <style>
        /* ── Breadcrumb ── */
        .breadcrumb-bar {
            background: var(--cool-grey);
            padding: 0.85rem 0;
            border-bottom: 1px solid var(--border);
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            list-style: none;
            font-size: 0.875rem;
            color: var(--muted);
        }

        .breadcrumb li+li::before {
            content: '/';
            margin-right: 0.5rem;
            color: var(--muted);
        }

        .breadcrumb a {
            color: var(--primary);
            transition: opacity 0.2s;
        }

        .breadcrumb a:hover {
            opacity: 0.75;
        }

        .breadcrumb .active {
            color: var(--foreground);
            font-weight: 500;
        }

        /* ── Blog hero banner ── */
        .blog-banner {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            border-bottom: 1px solid var(--border);
            padding: 4rem 0 0;
            text-align: center;
        }

        .blog-banner-meta {
            font-size: 0.85rem;
            color: var(--muted);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1rem;
        }

        .blog-banner-meta .tag {
            background: var(--primary-10);
            color: var(--primary);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.25rem 0.75rem;
            border-radius: 2rem;
        }

        .blog-banner h1 {
            font-size: clamp(1.75rem, 4vw, 2.75rem);
            color: var(--foreground);
            max-width: 820px;
            margin: 0 auto 2.5rem;
            line-height: 1.2;
        }

        .blog-banner-img {
            width: 100%;
            max-height: 420px;
            object-fit: cover;
            display: block;
        }

        .blog-banner-img-placeholder {
            width: 100%;
            height: 320px;
            background: linear-gradient(135deg, #dce8ff 0%, #c8d8ff 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 0.9rem;
        }

        /* ── Page layout ── */
        .blog-page {
            padding: 4rem 0 6rem;
            background: var(--background);
        }

        .blog-layout {
            display: grid;
            grid-template-columns: 260px 1fr;
            gap: 3.5rem;
            align-items: start;
        }

        /* ── Sidebar ── */
        .blog-sidebar {
            position: sticky;
            top: 5rem;
        }

        .toc-box {
            background: var(--cool-grey);
            border-radius: 0.75rem;
            padding: 1.5rem;
            border: 1px solid var(--border);
            margin-bottom: 1.5rem;
        }

        .toc-box>span {
            display: block;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .toc-box ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0;
        }

        .toc-box ul li a {
            display: block;
            padding: 0.3rem 0.5rem 0.3rem 0.75rem;
            font-size: 0.8rem;
            color: var(--muted);
            border-left: 2px solid var(--border);
            line-height: 1.4;
            transition: color 0.2s, border-color 0.2s;
        }

        .toc-box ul li a:hover,
        .toc-box ul li a.active {
            color: var(--primary);
            border-left-color: var(--primary);
        }

        .toc-box ul li.toc_heading3 a {
            padding-left: 1.4rem;
            font-size: 0.775rem;
        }

        /* Social share */
        .share-box {
            background: var(--cool-grey);
            border-radius: 0.75rem;
            padding: 1.25rem 1.5rem;
            border: 1px solid var(--border);
        }

        .share-box .share-label {
            font-size: 0.75rem;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 0.75rem;
            display: block;
        }

        .share-links {
            display: flex;
            gap: 0.6rem;
        }

        .share-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 2.2rem;
            height: 2.2rem;
            border-radius: 50%;
            background: var(--background);
            border: 1px solid var(--border);
            color: var(--foreground);
            font-size: 0.8rem;
            transition: background 0.2s, color 0.2s, border-color 0.2s;
            text-decoration: none;
        }

        .share-link:hover {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
        }

        /* ── Blog body ── */
        .blog-body {
            min-width: 0;
        }

        .blog-body p {
            font-size: 0.9375rem;
            color: #444;
            line-height: 1.85;
            margin-bottom: 1.1rem;
        }

        .blog-body h2 {
            font-size: 1.4rem;
            color: var(--foreground);
            margin: 2.5rem 0 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--primary-10);
            scroll-margin-top: 5rem;
            font-family: var(--font-heading);
        }

        .blog-body h3 {
            font-size: 1.1rem;
            color: var(--foreground);
            margin: 1.75rem 0 0.5rem;
            scroll-margin-top: 5rem;
            font-family: var(--font-heading);
        }

        .blog-body ul,
        .blog-body ol {
            list-style: none;
            margin: 0.5rem 0 1.25rem;
            display: flex;
            flex-direction: column;
            gap: 0.45rem;
        }

        .blog-body ul li,
        .blog-body ol li {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            font-size: 0.9375rem;
            color: #444;
            line-height: 1.7;
        }

        .blog-body ul li::before {
            content: '';
            flex-shrink: 0;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--primary);
            margin-top: 0.58rem;
        }

        .blog-body ol {
            counter-reset: ol-counter;
        }

        .blog-body ol li::before {
            content: counter(ol-counter);
            counter-increment: ol-counter;
            flex-shrink: 0;
            width: 1.4rem;
            height: 1.4rem;
            background: var(--primary);
            color: #fff;
            border-radius: 50%;
            font-size: 0.7rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 0.15rem;
        }

        .blog-body ul li strong,
        .blog-body ol li strong {
            color: var(--foreground);
        }

        .blog-body a {
            color: var(--primary);
            text-decoration: underline;
        }

        .blog-body strong {
            color: var(--foreground);
        }

        /* Inline CTA image placeholder */
        .blog-cta-banner {
            width: 100%;
            height: 120px;
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            border: 1px solid rgba(27, 84, 255, 0.15);
            border-radius: 0.6rem;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-weight: 600;
            font-size: 0.9rem;
            margin: 1.5rem 0;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .blog-cta-banner:hover {
            opacity: 0.85;
        }

        /* Cost table */
        .blog-body table {
            width: 100%;
            border-collapse: collapse;
            margin: 1rem 0 1.5rem;
            font-size: 0.875rem;
        }

        .blog-body table thead tr {
            background: var(--primary);
            color: #fff;
        }

        .blog-body table th {
            padding: 0.75rem 1rem;
            text-align: left;
            font-weight: 600;
        }

        .blog-body table td {
            padding: 0.65rem 1rem;
            color: #444;
            border-bottom: 1px solid var(--border);
        }

        .blog-body table tbody tr:nth-child(even) {
            background: #f8faff;
        }

        .blog-body table tbody tr:last-child td {
            font-weight: 700;
            color: var(--foreground);
            background: var(--primary-10);
        }

        /* FAQ accordion */
        .faq-section {
            margin-top: 2rem;
        }

        .faq-item {
            border: 1px solid var(--border);
            border-radius: 0.5rem;
            margin-bottom: 0.6rem;
            overflow: hidden;
        }

        .faq-header {
            padding: 1rem 1.25rem;
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--foreground);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            background: var(--background);
            transition: background 0.2s;
            user-select: none;
        }

        .faq-header:hover {
            background: #f8faff;
        }

        .faq-header.open {
            background: #f0f4ff;
            color: var(--primary);
        }

        .faq-icon {
            flex-shrink: 0;
            width: 1.25rem;
            height: 1.25rem;
            border-radius: 50%;
            background: var(--primary-10);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            line-height: 1;
            transition: transform 0.25s;
        }

        .faq-header.open .faq-icon {
            transform: rotate(45deg);
            background: var(--primary);
            color: #fff;
        }

        .faq-body {
            display: none;
            padding: 0 1.25rem 1rem;
            font-size: 0.9rem;
            color: #555;
            line-height: 1.75;
        }

        .faq-body.open {
            display: block;
        }

        /* ── Responsive ── */
        @@media (max-width: 960px) {
            .blog-layout {
                grid-template-columns: 1fr;
            }

            .blog-sidebar {
                position: static;
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 1rem;
            }

            .toc-box {
                max-height: 260px;
                overflow-y: auto;
            }
        }

        @@media (max-width: 600px) {
            .blog-sidebar {
                grid-template-columns: 1fr;
            }

            .blog-banner {
                padding: 3rem 0 0;
            }
        }
    </style>
}

