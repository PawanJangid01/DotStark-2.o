@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Rag>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}

    @section Styles {
  <style>

    :root {
      --bg: #ffffff;
      --fg: #1e293b;
      --primary: hsl(228, 100%, 55%);
      --primary-fg: #ffffff;
      --primary-10: hsl(228, 100%, 55%, 0.1);
      --primary-60: hsl(228, 100%, 55%, 0.6);
      --muted: #737373;
      --border: #e2e8f0;
      --accent-bg: #f8fafc;
      --card-shadow: 0 1px 3px rgba(0,0,0,0.06);
      --radius: 0.5rem;
    }

    body {
      font-family: 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
      background: var(--bg);
      color: var(--fg);
      -webkit-font-smoothing: antialiased;
      line-height: 1.6;
    }

    h1,h2,h3,h4,h5,h6 { letter-spacing: -0.03em; line-height: 1.3; }

    .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

    /* ---- Buttons ---- */
    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--primary); color: var(--primary-fg);
            padding: 0.6rem 1.4rem;
            border-radius: 0.5rem;
      font-size:14px; font-weight: 500; text-decoration: none;
      border: none; cursor: pointer; transition: filter 0.2s;
      position: relative; overflow: hidden;
    }
    .btn-primary:hover { filter: brightness(1.1); }
    .btn-primary::after {
      content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
      transition: left 0.5s ease;
    }
    .btn-primary:hover::after { left: 100%; }

    .btn-link {
      display: inline-flex; align-items: center; gap: 0.5rem;
      color: var(--primary); font-size: 0.875rem; font-weight: 500;
      text-decoration: none; transition: opacity 0.2s;
    }
    .btn-link:hover { opacity: 0.8; }



    .case-body .btn-link {
  display: inline-block;
  color: var(--primary);
  font-size: 14px;
  font-weight: 600;
  transition: transform 0.3s ease, color 0.3s ease;
}

.case-body .btn-link:hover {
  transform: translateY(-3px);
}
    /* ---- Grid Pattern ---- */
    .grid-pattern {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(hsla(220,13%,91%,0.5) 1px, transparent 1px),
        linear-gradient(90deg, hsla(220,13%,91%,0.5) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 50% at 50% 0%, black 70%, transparent 100%);
      -webkit-mask-image: radial-gradient(ellipse 80% 50% at 50% 0%, black 70%, transparent 100%);
    }

    /* ---- Cards ---- */
    .card {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--bg);
      transition: box-shadow 0.3s;
    }
    .card:hover { box-shadow: 0 10px 25px -5px rgba(0,0,0,0.08); }

    .icon-box {
      width: 48px; height: 48px; border-radius: 0.5rem;
      background: var(--primary-10);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .icon-box svg { width: 24px; height: 24px; color: var(--primary); }
    .icon-box-sm { width: 40px; height: 40px; }
    .icon-box-sm svg { width: 20px; height: 20px; }

    /* ---- Sections ---- */
    .section { padding: 5rem 0; }
    .section-alt { background: var(--cool-grey); }
    .section-header { max-width: 640px; margin: 0 auto 4rem; text-align: center; }
    .section-header h2 { font-size: clamp(1.875rem, 4vw, 3rem); font-weight: 600; }
    .section-header p { margin-top: 1rem; color: var(--muted); font-size: 1.0625rem; }

    .badge {
      display: inline-block; padding: 0.25rem 0.75rem;
      background: var(--primary-10); color: var(--primary);
      border-radius: 9999px; font-size: 0.75rem; font-weight: 600;
      margin-bottom: 1rem;
    }

    /* ---- Hero ---- */
    .hero {
      position: relative; overflow: hidden;
      padding: 10rem 0 6rem; text-align: center;
    }
    .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 700;
      max-width: 900px; margin: 0 auto;
      text-wrap: balance;
    }
    .hero h1 span{
                    color: var(--primary);
    }
    .hero .subtitle { max-width: 36rem; margin: 1.5rem auto 0; font-size: clamp(1.125rem, 2vw, 1.25rem); color: var(--muted); }
    .hero .subtext { max-width: 640px; margin: 1rem auto 0; font-size: 1rem; color: var(--muted); }
    .hero .cta-wrap { margin-top: 2.5rem; }

    /* ---- Grids ---- */
        .grid-3 {
            display: grid;
            gap: 1.5rem;
            grid-template-columns: repeat(auto-fit, minmax(min(320px, 100%), 1fr));
        }
    .grid-2 { display: grid; gap: 1.5rem; grid-template-columns: 1fr; }
    .grid-4 { display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
    @@media (min-width: 768px) { .grid-2 { grid-template-columns: 1fr 1fr; } }

        /* @@media (max-width: 567px) {
            .grid-3 {
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                
            }
        } */
    /* ---- Solution Card ---- */
        .solution-card {
            padding: 2rem;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            transition: border-color 0.2s;
            cursor: pointer;
            background-color: #ebebec59;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .solution-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);
            }

            .solution-card:before {
                content: "";
                position: absolute;
                inset: 0;
                padding: 1px; /* border thickness */
                border-radius: 0.5rem;
                --angle: 270deg;
                background: conic-gradient( from var(--angle), transparent 0deg, transparent 300deg, var(--primary) 330deg, transparent 360deg );
                z-index: 0;
                opacity: 0;
                pointer-events: none;
                /* Keep only border */
                -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
                -webkit-mask-composite: xor;
                mask-composite: exclude;
            }

        @@property --angle {
            syntax: "<angle>";
            inherits: false;
            initial-value: 270deg;
        }

        /* .solution-card::after {
            content: "";
            position: absolute;
            inset: 2px;
            /* background: #fff; */
            border-radius: 0.5rem;
            z-index: 0;
        } */

        .solution-card > * {
            position: relative;
            z-index: 2;
        }

        .solution-card:hover::before
        {
            opacity: 1;
            animation: snake-border 3.2s linear infinite;
        }

        @@keyframes snake-border {
            from {
                --angle: 270deg;
            }

            to {
                --angle: 630deg;
            }
        }
    .solution-card h3 { margin: 1.25rem 0 0.75rem; font-size: 1.125rem; font-weight: 600; }
    .solution-card p { font-size: 0.875rem; color: var(--muted); line-height: 1.7; }

    /* ---- Industry Card ---- */
        .industry-card {
            display: flex;
            gap: 1rem;
            padding: 1.5rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .industry-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);
        }
    .industry-card h4 { font-size: 0.875rem; font-weight: 600; margin-bottom: 0.25rem; }
    .industry-card p { font-size: 0.875rem; color: var(--muted); line-height: 1.65; }

    /* ---- Privacy Card ---- */
    .privacy-split {
      display: grid;
      grid-template-columns: 1fr;
      gap: 3rem;
      align-items: center;
    }
    @@media (min-width: 768px) {
      .privacy-split { grid-template-columns: 1fr 1fr; }
    }
    .privacy-text h2 { font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 600; margin-bottom: 1rem; }
    .privacy-text p { color: var(--muted); line-height: 1.7; font-size: 1rem; }
    .privacy-card { padding: 2.5rem; height: 100%; }
    .privacy-card .check-list li { font-size: 0.9375rem; padding: 0.625rem 0; border-bottom: 1px solid var(--border); }
    .privacy-card .check-list li:last-child { border-bottom: none; }
    .check-list { list-style: none; }
    .check-list li {
      display: flex; align-items: center; gap: 0.75rem;
      font-size: 0.875rem; padding: 0.375rem 0;
    }
    .check-list li svg { width: 16px; height: 16px; color: var(--primary); flex-shrink: 0; }

    /* ---- Case Study ---- */
    .case-card { overflow: hidden; max-width: 760px; margin: 0 auto; }
    .case-bar { height: 4px; background: hsl(228.21deg 100% 55.1%); }
    .case-body { padding: 2rem 3rem; }
    .case-body h3 { font-size: 1.5rem; font-weight: 600; margin: 1rem 0; }
    .case-body p { color: var(--muted); line-height: 1.7; margin-bottom: 2rem; }

    /* ---- RAG 365 ---- */
    .rag365-grid { display: grid; gap: 3rem; align-items: center; max-width: 900px; margin: 0 auto; }
    @@media (min-width: 768px) { .rag365-grid { grid-template-columns: 1fr 1fr; } }
    .rag365-grid h2 { font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 600; }
    .rag365-grid > div:first-child p { margin-top: 1rem; color: var(--muted); line-height: 1.7; }
    .rag365-grid .btn-primary { margin-top: 2rem; }
    .rag365-features { padding: 2rem; }
    .rag365-features li {
      display: flex; align-items: center; gap: 0.75rem;
      font-size: 0.875rem; padding: 0.5rem 0;
    }
    .rag365-features li svg { width: 20px; height: 20px; color: var(--primary); flex-shrink: 0; }

    /* ---- Expert Card ---- */
        .expert-card {
            padding: 1.75rem;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .expert-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px -5px rgba(0, 0, 0, 0.08);
        }
    .expert-card .icon-box { margin: 0 auto 1.25rem; }
    .expert-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; }
    .expert-card p { font-size: 0.875rem; color: var(--muted); line-height: 1.65; }
/* ══════════════════════════════════════════════
   10. CTA
   ══════════════════════════════════════════════ */
.cta-section {
    background: var(--primary);
    text-align: center;
}

    .cta-section .inner {
        max-width: 48rem;
        margin: 0 auto;
    }

    .cta-section h2 {
        font-size: clamp(1.875rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        margin-bottom: 1.5rem;
        line-height: 1.15;
    }

    .cta-section p {
        font-size: 1.125rem;
        font-family: var(--font-body);
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 2.5rem;
        line-height: 1.7;
    }

    .cta-section .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }

    /* ---- Animations ---- */
