<!-- 3b. PRIVACY -->
<section class="section">
  <div class="container">
    <div class="privacy-split fade-up">
      <div class="privacy-text">
        <div class="icon-box" style="margin-bottom:1.5rem;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <h2>Why Privacy Matters</h2>
        <p>RAG ensures your data stays within your control. Instead of sending sensitive information to external systems, it retrieves and processes data securely within your infrastructure or controlled environments.</p>
      </div>
      <div class="card privacy-card">
