<script>
    const headings = document.querySelectorAll('.blog-body h2[id], .blog-body h3[id]');
    const tocLinks = document.querySelectorAll('.toc-box a');
    const tocObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                tocLinks.forEach(link => { link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id); });
            }
        });
    }, { rootMargin: '-15% 0px -75% 0px' });
    headings.forEach(h => tocObserver.observe(h));
</script>
