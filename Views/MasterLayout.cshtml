    <script>
                        const mobileToggle = document.getElementById("mobileToggle");
        const mobileNav = document.getElementById("mobileNav");
        const iconMenu = document.getElementById("iconMenu");
        const iconClose = document.getElementById("iconClose");

        if (mobileToggle && mobileNav) {
          mobileToggle.addEventListener("click", () => {

            mobileNav.classList.toggle("open");

            const isOpen = mobileNav.classList.contains("open");
            mobileToggle.setAttribute("aria-expanded", isOpen);

            if (iconMenu && iconClose) {
              iconMenu.style.display = isOpen ? "none" : "block";
              iconClose.style.display = isOpen ? "block" : "none";
            }
          });
        }
        // ── Testimonial slider ──
        const slides = document.querySelectorAll('.testi-slide');
        let current = 0;
        let autoTimer;
        let typingInterval;

        function typeText(slide) {
          if (!slide) return;

          clearInterval(typingInterval);

          const blockquote = slide.querySelector("blockquote");
          if (!blockquote) return;

          let fullText = blockquote.getAttribute("data-text") || blockquote.textContent || "";

          // remove line breaks and extra spaces
          fullText = fullText.replace(/\s+/g, " ").trim();

          blockquote.setAttribute("data-text", fullText);
          blockquote.textContent = "";

          let index = 0;
          const speed = 55;

          typingInterval = setInterval(() => {
            blockquote.textContent += fullText.charAt(index);
            index++;

            if (index >= fullText.length) {
              clearInterval(typingInterval);
            }
          }, speed);
        }

        function showSlide(n) {
          if (!slides || slides.length === 0) return;

          if (slides[current]) {
            slides[current].classList.remove('active');
          }

          current = (n + slides.length) % slides.length;

          if (slides[current]) {
            slides[current].classList.add('active');
            typeText(slides[current]);
          }
        }

        function startAuto() {
          if (!slides || slides.length === 0) return;
          autoTimer = setInterval(() => showSlide(current + 1), 8000);
        }

        const testiPrev = document.getElementById('testiPrev');
        if (testiPrev) {
          testiPrev.addEventListener('click', () => {
            clearInterval(autoTimer);
            showSlide(current - 1);
            startAuto();
          });
        }

        const testiNext = document.getElementById('testiNext');
        if (testiNext) {
          testiNext.addEventListener('click', () => {
            clearInterval(autoTimer);
            showSlide(current + 1);
            startAuto();
          });
        }

        if (slides && slides.length > 0) {
          typeText(slides[current]);
          startAuto();
        }

        // ── Featured video play ──
        const playBtn = document.getElementById('testiPlayBtn');
        const thumb = document.getElementById('testiThumb');
        const video = document.getElementById('testiVideo');

        if (playBtn && thumb && video) {
          playBtn.addEventListener('click', () => {
            thumb.style.display = 'none';
            video.style.display = 'block';
            video.play();
          });
        }

        // Technology Stack tab switching
        const techTabs = document.querySelectorAll('.tech-tab');
        const techPanels = document.querySelectorAll('.tech-icons-panel');

        const tabMap = {
          'ai-models': 'tab-ai-models',
          frameworks: 'tab-frameworks',
          vectordb: 'tab-vectordb',
          cloud: 'tab-cloud',
          mlops: 'tab-mlops'
        };

        if (techTabs && techTabs.length > 0) {
          techTabs.forEach(btn => {
            btn.addEventListener('click', () => {
              techTabs.forEach(t => {
                t.classList.remove('active');
                t.setAttribute('aria-selected', 'false');
              });

              techPanels.forEach(p => p.classList.remove('active'));

              btn.classList.add('active');
              btn.setAttribute('aria-selected', 'true');

              const panelId = tabMap[btn.dataset.tab];
              const panel = document.getElementById(panelId);

              if (panel) {
                panel.classList.add('active');
              }
            });
          });
        }
    </script>
</body>

