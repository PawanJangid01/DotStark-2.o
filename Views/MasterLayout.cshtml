  <script>
    // â”€â”€ Testimonial slider â”€â”€
    const slides = document.querySelectorAll('.testi-slide');
    let current = 0;
    let autoTimer;
            function typeText(slide) {
          const blockquote = slide.querySelector("blockquote");
          const fullText = blockquote.getAttribute("data-text") || blockquote.textContent;

          blockquote.setAttribute("data-text", fullText);
          blockquote.textContent = "";

          let index = 0;
          const speed = 40; // typing speed

          const typing = setInterval(() => {
            blockquote.textContent += fullText.charAt(index);
            index++;

            if (index >= fullText.length) {
              clearInterval(typing);
            }
          }, speed);
        }

    function showSlide(n) {
      slides[current].classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
           typeText(slides[current]);
    }

    function startAuto() {
      autoTimer = setInterval(() => showSlide(current + 1), 8000);
    }

    document.getElementById('testiPrev').addEventListener('click', () => {
      clearInterval(autoTimer);
      showSlide(current - 1);
      startAuto();
    });

    document.getElementById('testiNext').addEventListener('click', () => {
      clearInterval(autoTimer);
      showSlide(current + 1);
      startAuto();
    });
        typeText(slides[current]);
    startAuto();

    // â”€â”€ Featured video play â”€â”€
    const playBtn = document.getElementById('testiPlayBtn');
    const thumb = document.getElementById('testiThumb');
    const video = document.getElementById('testiVideo');
    if (playBtn) {
      playBtn.addEventListener('click', () => {
        thumb.style.display = 'none';
        video.style.display = 'block';
        video.play();
      });
    }

    // Technology Stack tab switching
    const techTabs = document.querySelectorAll('.tech-tab');
    const techPanels = document.querySelectorAll('.tech-icons-panel');
    const tabMap = {
      'ai-models': 'tab-ai-models', frameworks: 'tab-frameworks',
      vectordb: 'tab-vectordb', cloud: 'tab-cloud', mlops: 'tab-mlops'
    };
    techTabs.forEach(btn => {
      btn.addEventListener('click', () => {
        techTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        techPanels.forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        btn.setAttribute('aria-selected', 'true');
        document.getElementById(tabMap[btn.dataset.tab]).classList.add('active');
      });
    });
  </script>
