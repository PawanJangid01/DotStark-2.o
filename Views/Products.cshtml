@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Products>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}
@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --primarycss:228,100%,55%;
  --bg:#ffffff;
  --fg:#111111;
  --surface:#f5f5f5;
  --border:#e5e5e5;
  --muted:#6b7280;
  --secondary-bg:#ebebec;
  --radius:0.75rem;
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--fg);-webkit-font-smoothing:antialiased;line-height:1.6}
a{color:inherit;text-decoration:none}
img{max-width:100%}

/* Layout */
.section{padding:5rem 1.5rem}
.container{max-width:72rem;margin:0 auto}
.text-center{text-align:center}
.grid-2{display:grid;grid-template-columns:1fr;gap:1.5rem}
.grid-3{display:grid;grid-template-columns:1fr;gap:1.5rem}
.grid-4{display:grid;grid-template-columns:1fr;gap:1.5rem}
@@media(min-width:640px){.grid-2,.grid-3{grid-template-columns:repeat(2,1fr)}.sm-grid-3{grid-template-columns:repeat(3,1fr)}}
@@media(min-width:768px){.grid-3{grid-template-columns:repeat(3,1fr)}.grid-2{grid-template-columns:repeat(2,1fr)}.grid-4{grid-template-columns:repeat(2,1fr)}}
@@media(min-width:1024px){.grid-4{grid-template-columns:repeat(4,1fr)}}

/* Typography */
.gradient-text{background:linear-gradient(135deg,hsl(228,100%,55%),hsl(228,100%,72%));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.label{font-size:.75rem;font-weight:600;color:hsl(var(--primarycss));text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem}
.heading{font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;line-height:1.15;margin-bottom:3rem}
.hero-heading{font-size:clamp(2.25rem,5vw,4rem);font-weight:800;line-height:1.05;letter-spacing:-.02em;margin-bottom:1.25rem}
.subtext{font-size:1.125rem;color:var(--muted);max-width:48rem;margin:0 auto 2rem}
.muted{color:var(--muted)}

/* Cards */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem}
.stat-card{text-align:center}
.stat-value{font-size:1.875rem;font-weight:700}
.stat-label{font-size:.875rem;font-weight:600;margin-top:.25rem}
.stat-sub{font-size:.75rem;color:var(--muted);margin-top:.25rem}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:.5rem;padding:.875rem 2rem;border-radius:var(--radius);font-weight:600;font-size:1rem;border:none;cursor:pointer;transition:all .2s}
.btn-primary{background:hsl(var(--primarycss));color:#fff;box-shadow:0 0 24px -4px hsla(var(--primarycss),.4)}
.btn-primary:hover{opacity: 0.9;}
.btn-outline{background:transparent;border:1px solid hsla(var(--primarycss),.4);color:var(--fg)}
.btn-outline:hover{opacity: 0.9;}
.btn-group{display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center}

/* Pill Badge */
.pill{display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1rem;border-radius:9999px;border:1px solid var(--border);background:var(--secondary-bg);font-size:.875rem;color:var(--muted);margin-bottom:2rem}
.pill-dot{width:.5rem;height:.5rem;border-radius:50%;background:hsl(var(--primarycss))}

/* Icon box */
.icon-box{width:2.5rem;height:2.5rem;border-radius:.5rem;background:hsla(var(--primarycss),.1);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;color:hsl(var(--primarycss));font-weight:700;font-size:1rem}

/* Tag */
.tag{font-size:.7rem;font-weight:600;color:hsl(var(--primarycss));text-transform:uppercase;letter-spacing:.08em}

/* Mockup */
.mockup{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem}
.mockup-query{background:hsla(var(--primarycss),.08);border:1px solid hsla(var(--primarycss),.2);border-radius:.5rem;padding:1rem;margin-bottom:1rem}
.mockup-response{background:var(--secondary-bg);border:1px solid var(--border);border-radius:.5rem;padding:1rem}
.mockup-label{font-size:.875rem;font-weight:600;color:hsl(var(--primarycss));margin-bottom:.5rem}
.mockup-result{font-size:.75rem;padding:.5rem;border-radius:.25rem;background:var(--bg);border:1px solid var(--border);margin-bottom:.5rem;color:var(--muted)}
.mockup-result.active{background:hsla(var(--primarycss),.05);border-color:hsla(var(--primarycss),.2);color:var(--fg);font-weight:500}
.mockup-result .ts{color:hsl(var(--primarycss));font-family:monospace}

/* Step number */
.step-num{font-size:2.5rem;font-weight:900;opacity:.2}

/* Border section */
.bordered{border-top:1px solid var(--border);border-bottom:1px solid var(--border)}

/* Reveal animation */
.reveal{opacity:0;transform:translateY(20px);filter:blur(4px);transition:all .7s cubic-bezier(.16,1,.3,1)}
.reveal.visible{opacity:1;transform:translateY(0);filter:blur(0)}
.reveal-delay-1{transition-delay:.1s}
.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}
.reveal-delay-4{transition-delay:.4s}

/* Grid bg */
.grid-bg{position:relative;overflow:hidden}
/* .grid-bg::before{content:'';position:absolute;inset:0;opacity:.03;background-image:linear-gradient(hsl(var(--primarycss)) 1px,transparent 1px),linear-gradient(90deg,hsl(var(--primarycss)) 1px,transparent 1px);background-size:64px 64px} */

/* Hero specific */
.hero{min-height:85vh;display:flex;align-items:center;justify-content:center}

/* Responsive padding */
@@media(min-width:768px){.section{padding:6rem 2rem}}
@@media(min-width:1024px){.section{padding:5rem 2rem}}

@@media(min-width:1024px){.hero{padding:10rem 9rem 0}}
/* Lists */
ul.feature-list{list-style:disc;padding-left:1.25rem;font-size:.875rem;color:var(--muted)}
ul.feature-list li{margin-bottom:.25rem}



/* ══════════════════════════════════════════════
   6. PROCESS
   ══════════════════════════════════════════════ */
.process {
    background: #f8faff;
}

    .process .process-header {
        max-width: 48rem;
        margin-bottom: 4rem;
    }

        .process .process-header h2 {
            font-size: clamp(1.875rem, 4vw, 3rem);
            font-weight: 700;
            color: var(--foreground);
            margin-bottom: 0.75rem;
        }

.process-subtext {
    font-family: var(--font-body);
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
}

.process .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
}

@@media (min-width: 768px) {
    .process .steps-grid {
        grid-template-columns: repeat(4, 1fr);
    }
}

/* Step card */
.step-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1.2rem 1.5rem;
    position: relative;
    transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    overflow: hidden;
}

    .step-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--primary);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.3s ease;
    }

    .step-card:hover {
        border-color: var(--primary-30);
        box-shadow: 0 8px 28px rgba(27, 84, 255, 0.1);
        transform: translateY(-4px);
    }

        .step-card:hover::before {
            transform: scaleX(1);
        }

.step-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--primary);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: var(--font-heading);
    margin-bottom: 1.25rem;
}

.step-icon {
    color: var(--primary);
    margin-bottom: 1rem;
}

.step-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--foreground);
    margin-bottom: 0.5rem;
}

.step-card p {
    font-family: var(--font-body);
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.95rem;
}

section {
  scroll-margin-top: 80px; /* Example value */
}


/* ══════════════════════════════════════════════
   10. CTA
   ══════════════════════════════════════════════ */
.cta-section {
    background: var(--primary);
    text-align: center;
}

    .cta-section .inner {
        max-width: 48rem;
        margin: 0 auto;
    }

    .cta-section h2 {
        font-size: clamp(1.875rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        margin-bottom: 1.5rem;
        line-height: 1.15;
    }

    .cta-section p {
        font-size: 1.125rem;
        font-family: var(--font-body);
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 2.5rem;
        line-height: 1.7;
    }

    .cta-section .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }


</style>
}

<!-- HERO -->
<section class="section hero grid-bg">
<div class="container text-center" style="position:relative">
  <h1 class="hero-heading reveal reveal-delay-1">Intelligence That Works <span class="gradient-text">For You</span></h1>
