  <div class="btn-group reveal reveal-delay-3">
    <a href="#rag365" class="btn btn-primary">Explore RAG365 →</a>
    <a href="#reclass" class="btn btn-outline">Explore ReClass AI →</a>
  </div>
</div>
</section>

