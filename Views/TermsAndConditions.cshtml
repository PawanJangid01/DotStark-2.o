@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.TermsAndConditions>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}

@section Styles {
    <style>
        /* ── Breadcrumb ── */
        .breadcrumb-bar {
            background: var(--cool-grey);
            padding: 0.85rem 0;
            border-bottom: 1px solid var(--border);
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            list-style: none;
            font-size: 0.875rem;
            color: var(--muted);
        }

        .breadcrumb li+li::before {
            content: '/';
            margin-right: 0.5rem;
            color: var(--muted);
        }

        .breadcrumb a {
            color: var(--primary);
            transition: opacity 0.2s;
        }

        .breadcrumb a:hover {
            opacity: 0.75;
        }

        .breadcrumb .active {
            color: var(--foreground);
            font-weight: 500;
        }

        /* ── Hero ── */
        .tc-hero {
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            padding: 5rem 0 4rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            border-bottom: 1px solid var(--border);
        }

        .tc-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(27, 84, 255, 0.1) 0%, transparent 70%);
            pointer-events: none;
        }

        .tc-hero h1 {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            color: var(--foreground);
            position: relative;
        }

        .tc-hero h1 span {
            color: var(--primary);
        }

        .tc-hero p {
            margin-top: 1rem;
            color: var(--muted);
            font-size: 1rem;
            position: relative;
        }

        /* ── Content ── */
        .tc-content {
            padding: 5rem 0 6rem;
            background: var(--background);
        }

        .tc-layout {
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 4rem;
            align-items: start;
        }

        /* Sticky sidebar TOC */
        .tc-toc {
            position: sticky;
            top: 5rem;
        }

        .tc-toc h3 {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 1rem;
        }

        .tc-toc ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
        }

        .tc-toc a {
            display: block;
            padding: 0.4rem 0.75rem;
            font-size: 0.875rem;
            color: var(--muted);
            border-left: 2px solid var(--border);
            transition: color 0.2s, border-color 0.2s;
        }

        .tc-toc a:hover,
        .tc-toc a.active {
            color: var(--primary);
            border-left-color: var(--primary);
        }

        /* Main body */
        .tc-body {
            min-width: 0;
        }

        .tc-body p {
            font-size: 0.9375rem;
            color: #444;
            line-height: 1.8;
            margin-bottom: 1.25rem;
        }

        .tc-body h2 {
            font-size: 1.35rem;
            color: var(--foreground);
            margin: 2.5rem 0 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid var(--primary-10);
            scroll-margin-top: 5rem;
        }

        .tc-body h2 .section-num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 1.75rem;
            height: 1.75rem;
            background: var(--primary);
            color: #fff;
            border-radius: 50%;
            font-size: 0.75rem;
            font-weight: 700;
            margin-right: 0.6rem;
            vertical-align: middle;
        }

        .tc-body ul {
            list-style: none;
            margin: 0.5rem 0 1.25rem 0;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .tc-body ul li {
            display: flex;
            align-items: flex-start;
            gap: 0.6rem;
            font-size: 0.9375rem;
            color: #444;
            line-height: 1.7;
        }

        .tc-body ul li::before {
            content: '';
            flex-shrink: 0;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--primary);
            margin-top: 0.55rem;
        }

        /* Intro card */
        .tc-intro-card {
            background: #f0f4ff;
            border-radius: 0.75rem;
            padding: 2rem 2.25rem;
            margin-bottom: 2.5rem;
            border-left: 4px solid var(--primary);
        }

        .tc-intro-card p {
            color: #444;
            margin-bottom: 0;
        }

        .tc-intro-card p+p {
            margin-top: 0.75rem;
        }

        .tc-intro-card strong {
            color: var(--foreground);
        }

        /* Last updated badge */
        .tc-meta {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 2.5rem;
            flex-wrap: wrap;
        }

        .tc-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            background: var(--primary-10);
            color: var(--primary);
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.35rem 0.85rem;
            border-radius: 2rem;
        }

        .tc-badge svg {
            flex-shrink: 0;
        }

        /* Contact CTA */
        .tc-contact-cta {
            margin-top: 3rem;
            background: linear-gradient(135deg, #f0f4ff 0%, #e8eeff 100%);
            border-radius: 0.75rem;
            padding: 2.5rem;
            text-align: center;
            border: 1px solid rgba(27, 84, 255, 0.15);
        }

        .tc-contact-cta h3 {
            color: var(--foreground);
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        .tc-contact-cta p {
            color: var(--muted);
            margin-bottom: 1.5rem;
        }

        /* ── Responsive ── */
        @@media (max-width: 900px) {
            .tc-layout {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .tc-toc {
                position: static;
                background: var(--cool-grey);
                border-radius: 0.5rem;
                padding: 1.25rem 1.5rem;
            }

            .tc-toc ul {
                flex-direction: row;
                flex-wrap: wrap;
                gap: 0.5rem;
            }

            .tc-toc a {
                border-left: none;
                border-bottom: 2px solid var(--border);
                padding: 0.3rem 0.5rem;
            }

            .tc-toc a:hover,
            .tc-toc a.active {
                border-bottom-color: var(--primary);
                border-left-color: transparent;
            }
        }

        @@media (max-width: 600px) {
            .tc-hero {
                padding: 3.5rem 0 3rem;
            }

            .tc-content {
                padding: 3rem 0 4rem;
            }

            .tc-intro-card {
                padding: 1.5rem;
            }
        }
    </style>
}

