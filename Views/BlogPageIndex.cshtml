    .blog-body ul li, .blog-body ol li {  align-items: flex-start; gap: 0.6rem; font-size: 0.9375rem; color: #737373; line-height: 1.7; }
    .blog-body ul li::before { content: ''; flex-shrink: 0; width: 6px; height: 6px; border-radius: 50%; background: #353535; margin-top: 0.58rem; }
