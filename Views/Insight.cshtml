@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.Insight>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = "MasterLayout.cshtml";
}
  @section Styles {
  <style>
    :root {
      --ds-primary: #0040FF;
      --ds-dark: #0f172a;
      --ds-bg: #ffffff;
      --ds-secondary: #f1f5f9;
      --ds-border: #e2e8f0;
      --ds-muted: #64748b;
      --ds-card: #ffffff;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--ds-bg);
      color: var(--ds-dark);
      line-height: 1.6;
    }

    a { text-decoration: none; color: inherit; }
    img { display: block; max-width: 100%; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

    /* ── Hero ── */
    .hero {
      position: relative; padding: 160px 0 80px; text-align: center; overflow: hidden;
    }
    .hero-circles {
      position: absolute; top: 40px; right: 0; width: 400px; height: 400px; opacity: 0.05;
    }
    .hero-circles div {
      position: absolute; border-radius: 50%; border: 2px solid var(--ds-primary);
    }
    .hero-circles .c1 { inset: 0; }
    .hero-circles .c2 { inset: 48px; }
    .hero-circles .c3 { inset: 96px; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--ds-secondary); padding: 8px 16px; border-radius: 50px;
      font-size: 14px; color: var(--ds-muted); margin-bottom: 24px;
    }
    .hero-badge .dot {
      width: 8px; height: 8px; border-radius: 50%; background: var(--ds-primary);
      animation: pulse 2s infinite;
    }
    @@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
    .hero h1 { font-size: clamp(36px, 5vw, 56px); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 20px; }
    .hero h1 .accent { color: var(--ds-primary); }
    .hero p { font-size: 18px; color: var(--ds-muted); max-width: 640px; margin: 0 auto; }

    /* ── Section Commons ── */
    .section { padding: 96px 0; }
    .section.alt { background: var(--ds-secondary); }
    .section-label {
      font-size: 12px; font-weight: 700; color: var(--ds-primary);
      text-transform: uppercase; letter-spacing: 3px; margin-bottom: 12px;
    }
    .section-title { font-size: clamp(28px, 3.5vw, 40px); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 12px; }
    .section-desc { font-size: 16px; color: var(--ds-muted); max-width: 640px; margin: 0 auto 56px; }
    .section-header { text-align: center; margin-bottom: 56px; }

    /* ── Cards Grid ── */
    .cards-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
    @@media (max-width: 900px) { .cards-grid { grid-template-columns: 1fr; } }

    .card {
      background: var(--ds-card); border-radius: 16px; border: 1px solid var(--ds-border);
      overflow: hidden; transition: box-shadow 0.3s, border-color 0.3s;
    }
    .card:hover { box-shadow: 0 20px 40px rgba(0,0,0,0.08); border-color: rgba(0,64,255,0.3); }
    .card-img { position: relative; height: 210px; overflow: hidden; }
    .card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .card:hover .card-img img { transform: scale(1.05); }
    .card-tag {
      position: absolute; top: 16px; left: 16px;
      background: var(--ds-primary); color: #fff; font-size: 12px; font-weight: 600;
      padding: 4px 12px; border-radius: 50px;
    }
    .card-body { padding: 24px; }
    .card-body h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; line-height: 1.4; transition: color 0.2s; }
    .card:hover .card-body h3 { color: var(--ds-primary); }
    .card-body p { font-size: 14px; color: var(--ds-muted); line-height: 1.7; margin-bottom: 14px; }
    .card-meta { display: flex; align-items: center; gap: 16px; font-size: 12px; color: var(--ds-muted); margin-bottom: 12px; }
    .card-meta svg { width: 12px; height: 12px; }
    .card-author { display: flex; align-items: center; gap: 8px; padding-top: 8px; }
    .card-author .avatar {
      width: 28px; height: 28px; border-radius: 50%; background: rgba(0,64,255,0.1);
      display: flex; align-items: center; justify-content: center;
    }
    .card-author .avatar svg { width: 14px; height: 14px; color: var(--ds-primary); }
    .card-author span { font-size: 12px; font-weight: 500; color: var(--ds-muted); }

    .read-link {
      display: inline-flex; align-items: center; gap: 8px;
      color: var(--ds-primary); font-size: 14px; font-weight: 600; transition: gap 0.2s;
    }
    .read-link:hover { gap: 12px; }
    .read-link svg { width: 14px; height: 14px; }

    /* ── Load More ── */
    .load-more-wrap { text-align: center; margin-top: 48px; }
    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      border: 1px solid var(--ds-border); background: transparent; color: var(--ds-dark);
      padding: 14px 32px; border-radius: 50px; font-size: 14px; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .btn-outline:hover { background: var(--ds-card); border-color: rgba(0,64,255,0.3); }
    .btn-outline svg { width: 14px; height: 14px; }

    /* ── Stats ── */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    @@media (max-width: 768px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
    .stat-card {
      background: var(--ds-card); border: 1px solid var(--ds-border); border-radius: 12px;
      padding: 32px; text-align: center; transition: all 0.3s;
    }
    .stat-card:hover { border-color: rgba(0,64,255,0.3); box-shadow: 0 10px 30px rgba(0,0,0,0.06); }
    .stat-card .value { font-size: clamp(28px, 3vw, 40px); font-weight: 800; color: var(--ds-primary); margin-bottom: 8px; }
    .stat-card .label { font-size: 14px; color: var(--ds-muted); font-weight: 500; }


    /* ══════════════════════════════════════════════
   10. CTA
   ══════════════════════════════════════════════ */
.cta-section {
    background: var(--primary);
    text-align: center;
}

    .cta-section .inner {
        max-width: 48rem;
        margin: 0 auto;
    }

    .cta-section h2 {
        font-size: clamp(1.875rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        margin-bottom: 1.5rem;
        line-height: 1.15;
    }

    .cta-section p {
        font-size: 1.125rem;
        font-family: var(--font-body);
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 2.5rem;
        line-height: 1.7;
    }

    .cta-section .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
    }

  </style>
}

