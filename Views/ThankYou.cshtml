@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.ThankYou>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@{
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thank You | DotStark</title>
  <meta name="description" content="Thank you for contacting DotStark. We appreciate your interest.">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" href="/images/ds_favicon.jpg" type="image/png" /> 
  <style>
    :root {
      --ds-primary: #1b54ff;
      --ds-dark: #0f172a;
      --ds-white: #ffffff;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .bg-layer {
      position: absolute;
      z-index: 0;
    }

    /* Animated floating dots */
    .bg-layer::before,
    .bg-layer::after {
      content: '';
      position: absolute;
      border-radius: 50%;
      background: rgba(0, 64, 255, 0.2);
      animation: float 8s ease-in-out infinite;
    }
    .bg-layer::before {
      width: 300px; height: 300px;
      top: -80px; right: -60px;
      animation-delay: 0s;
    }
    .bg-layer::after {
      width: 200px; height: 200px;
      bottom: -50px; left: -40px;
      animation-delay: 4s;
    }

    @@keyframes float {
      0%, 100% { transform: translateY(0) scale(1); opacity: 0.2; }
      50% { transform: translateY(-30px) scale(1.05); opacity: 0.35; }
    }

    .content-wrapper {
      position: relative;
      z-index: 1;
      text-align: center;
      /* max-width: 520px; */
      padding: 3rem 1.5rem;
    }

    /* Logo */
    .logo {
      font-size: 2rem;
      font-weight: 800;
      color: var(--ds-white);
      letter-spacing: -0.5px;
      margin-bottom: 3rem;
    }
    .logo span { color: var(--ds-primary); }

    /* Thank You */
    h1 {
      font-size: 3rem;
      font-weight: 800;
      color: var(--ds-white);
      margin-bottom: 1rem;
    }

    .thank-title {
  font-size: 3rem;
  font-weight: 700;
  text-align: center;
  white-space: nowrap; /* force single line */
  color: #000000;
}

.thank-title span {
  color: var(--ds-primary); /* blue part */
}


    .subtitle {
      color: rgb(0 0 0);
      font-size: 1.1rem;
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }

    /* Let's Connect */
    .connect-title {
      color: rgba(0 0 0);
      font-weight: 700;
      font-size: 1.25rem;
      margin-bottom: 1.5rem;
    }

    /* Social Icons */
    .social-icons {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
      margin-bottom: 3rem;
    }
    .social-icons a {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 1px solid #1b54ff;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #1b54ff;
      font-size: 1.15rem;
      text-decoration: none;
      transition: all 0.3s ease;
    }
    .social-icons a:hover {
      background: var(--ds-primary);
      border-color: var(--ds-primary);
      color: var(--ds-white);
      transform: translateY(-3px);
    }

    /* Button */
    .btn-home {
      display: inline-block;
      padding: 0.85rem 2.5rem;
      border-radius: 50px;
      background: var(--ds-primary);
      color: var(--ds-white);
      font-weight: 600;
      font-size: 0.95rem;
      text-decoration: none;
      transition: opacity 0.3s, transform 0.3s;
    }
    .btn-home:hover {
      opacity: 0.9;
      color: var(--ds-white);
      transform: translateY(-2px);
    }

    @@media (max-width: 576px) {
      h1 { font-size: 2.25rem; }
      .social-icons a { width: 42px; height: 42px; font-size: 1rem; }
    }
  </style>
</head>
<body>

  <div class="bg-layer"></div>

  <div class="content-wrapper">
    <!-- Logo -->
    <div class="logo"><img src="/images/dotstark_2.o.png" alt="DotStark Logo" style="height: 85px;" /></div>

    <!-- Thank You Message -->
    <h1 class="thank-title">Thank you for <span>contacting us!</span></h1>
    <p class="subtitle">We have received your request and our team will contact you within 24 hours.</p>

    <!-- Let's Connect -->
    <p class="connect-title">Let's Connect!</p>

    <!-- Social Media Icons -->
    <div class="social-icons">
      <a href="#" aria-label="LinkedIn" target="_blank" rel="noopener"><i class="bi bi-linkedin"></i></a>
      <a href="#" aria-label="Twitter" target="_blank" rel="noopener"><i class="bi bi-twitter-x"></i></a>
      <a href="#" aria-label="Facebook" target="_blank" rel="noopener"><i class="bi bi-facebook"></i></a>
      <a href="#" aria-label="Instagram" target="_blank" rel="noopener"><i class="bi bi-instagram"></i></a>
      <a href="#" aria-label="YouTube" target="_blank" rel="noopener"><i class="bi bi-youtube"></i></a>
    </div>

    <!-- Back to Home -->
    <a href="/" class="btn-home">Back to Home</a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
