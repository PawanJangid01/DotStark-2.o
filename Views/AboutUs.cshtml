    @section Styles {
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--primaryblue:228,100%,55%;--bg:#fff;--fg:#111;--muted:#64748b;--surface:#f8fafc;--border:#e2e8f0;--card:#fafafa;--radius:0.75rem}
body{font-family:'Inter',sans-serif;color:var(--fg);line-height:1.6;-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}

.section1-padding{padding:5rem 1.5rem}
.hero-padding{padding:10rem 1.5rem}
.max-w-5xl{max-width:64rem;margin:0 auto}
.max-w-6xl{max-width:72rem;margin:0 auto}
.max-w-4xl{max-width:56rem;margin:0 auto}
.text-center{text-align:center}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:.5rem;padding:0.6rem 1.4rem;border-radius:var(--radius);font-weight:600;font-size:14px;cursor:pointer;transition:all .2s;border:none}
.btn-primary{background:hsl(var(--primaryblue));color:#fff}
.btn-primary:hover{background:hsl(228,100%,48%)}
.btn-outline{background:transparent;border:1px solid var(--border);color:var(--fg)}
.btn-outline:hover{background:var(--surface)}

/* Tags */
.tag{display:inline-flex;align-items:center;gap:.5rem;padding:.5rem 1rem;border-radius:999px;border:1px solid var(--border);background:hsl(228,60%,96%);font-size:.875rem;color:var(--muted)}

/* Section headers */
.section-label{font-size:.75rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:hsl(var(--primaryblue));margin-bottom:.75rem}
.section-title{font-size:clamp(1.8rem, 3.5vw, 2.5rem);font-weight:700;color:var(--fg);margin-bottom:1rem;line-height:1.3}
.section-desc{font-size:1.125rem;color:var(--muted);max-width:40rem;margin:0 auto 3rem}

/* Cards */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:2rem;transition:box-shadow .3s}
.card:hover{box-shadow:0 10px 40px -12px rgba(0,0,0,.1)}
.card-icon{width:3rem;height:3rem;border-radius:.75rem;background:hsl(var(--primaryblue)/.1);display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem}
.card-icon svg{width:1.5rem;height:1.5rem;color:hsl(var(--primaryblue));stroke:hsl(var(--primaryblue));fill:none}
.card h3{font-size:1.25rem;font-weight:700;margin-bottom:.75rem}
.card p{color:var(--muted);font-size:.9375rem;line-height:1.7}

/* Grid */
.grid-2{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:2rem}
.grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem}

/* Hero */
.hero{min-height:85vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;opacity:.03;}
.hero h1{font-size:clamp(2.25rem, 5vw, 3.75rem);font-weight:700;line-height:1.05;margin-bottom:1.3rem}
.hero h1 span{color:hsl(var(--primaryblue))}
.hero p{font-size:1.125rem;color:var(--muted);max-width:48rem;margin:0 auto 1rem}
.hero .btn-group{display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;margin-top:2.5rem}

/* Alt bg */
.bg-alt{background:#ebebec}

/* Values */
.value-num{font-size:2.5rem;font-weight:900;color:hsl(var(--primaryblue)/.12);margin-bottom:.5rem}

/* Leader */
.leader-avatar{width:4rem;height:4rem;border-radius:50%;background:hsl(var(--primaryblue)/.1);display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem}
.leader-avatar svg{width:2rem;height:2rem;stroke:hsl(var(--primaryblue));fill:none}
.leader-role{font-size:.875rem;font-weight:600;color:hsl(var(--primaryblue));margin-bottom:.75rem}

/* Highlights */
.highlight-item{display:flex;gap:.75rem;align-items:flex-start;margin-bottom:1rem}
.highlight-check{width:1.25rem;height:1.25rem;color:hsl(var(--primaryblue));flex-shrink:0;margin-top:.2rem}

/* Diff card */
.diff-card{display:flex;gap:1.25rem;padding:1.5rem;border-radius:var(--radius);border:1px solid var(--border);background:var(--card);transition:box-shadow .3s}
.diff-card:hover{box-shadow:0 10px 40px -12px rgba(0,0,0,.1)}

/* CTA */
.cta-section{text-align:center;padding:5rem 0;}
.cta-section h2{font-size:clamp(1.75rem,4vw,2.5rem);font-weight:800;margin-bottom:1rem}
.cta-section h2 span{color:hsl(var(--primaryblue))}
.cta-section .highlight-text{font-size:1.125rem;font-weight:600;margin:2rem 0}

/* Reveal */
.reveal{opacity:0;transform:translateY(24px);filter:blur(4px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1),filter .7s cubic-bezier(.16,1,.3,1)}
.reveal.visible{opacity:1;transform:translateY(0);filter:blur(0)}

@@media(max-width:768px){
  .section1-padding{padding:5rem 2rem}
  .grid-2,.grid-3{grid-template-columns:1fr}
  .hero{min-height:auto;padding:10rem 1rem 5rem}
  .btn{padding:.75rem 1.5rem;font-size:.9375rem}
  .diff-card{flex-direction:column}
}


