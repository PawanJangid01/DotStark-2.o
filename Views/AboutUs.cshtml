  color: #6b7280;
  line-height: 1.6;
}

/* Responsive */
@@media (max-width: 1024px) {
  .team-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@@media (max-width: 768px) {
  .team-grid {
    grid-template-columns: 1fr;
  }
}

</style>
